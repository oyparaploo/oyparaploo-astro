---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/400-italic.css';
import '@fontsource/lora/500.css';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Oyparaploo</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #0e0e0e;
        color: #d4d0c8;
        font-family: 'Inter', sans-serif;
        font-size: 1.0625rem;
        line-height: 1.7;
        padding: 4rem 2rem;
        max-width: 680px;
        margin: 0 auto;
      }

      h1 {
        font-family: 'Lora', serif;
        font-weight: 400;
        font-size: 1.5rem;
        color: #e8e4da;
        margin-bottom: 3rem;
        letter-spacing: 0.01em;
      }

      ul {
        list-style: none;
      }

      li {
        margin-bottom: 1.25rem;
      }

      a {
        color: #c8b99a;
        text-decoration: none;
        font-family: 'Lora', serif;
        font-size: 1.0625rem;
      }

      a:hover {
        color: #e8e4da;
      }

      .date {
        font-size: 0.8125rem;
        color: #6b6760;
        margin-left: 1rem;
      }
    </style>
  </head>
  <body>
    <h1>Oyparaploo</h1>
    <ul>
      <li>
        <a href="#">The Big River Is Something Very Deep That Runs Inside of Us</a>
        <span class="date">May 2, 2026</span>
      </li>
      <li>
        <a href="#">When We Become Subdued in Sunlight</a>
        <span class="date">May 2, 2026</span>
      </li>
      <li>
        <a href="#">Who Is The One</a>
        <span class="date">May 2, 2026</span>
      </li>
      <li>
        <a href="#">We Want to Be Honest About Which Kind of Fun We're Having</a>
        <span class="date">May 2, 2026</span>
      </li>
      <li>
        <a href="#">Oy and O Question of the First Sound (rigor)</a>
        <span class="date">May 1, 2026</span>
      </li>
      <li>
        <a href="#">oO'open</a>
        <span class="date">May 1, 2026</span>
      </li>
    </ul>
  </body>
</html>