<div class="menu-panel" id="menuPanel" role="dialog"><div class="menu-top"><span class="menu-ghost-wordmark">oyparaploo</span><button class="menu-close" id="menuCloseBtn">&#10005;</button></div><div class="menu-content"><nav class="menu-nav-primary"><a href="#">Writing</a><a href="#">Making</a><a href="#">Good Grounds</a></nav><hr class="menu-rule-tan"><nav class="menu-nav-secondary"><a href="#">Our Practice</a><a href="#">Music Artists</a><a href="#">Collaborators</a><a href="#">Methodology</a></nav><hr class="menu-rule-sage"><nav class="menu-nav-tertiary"><a href="#">Support</a><a href="#">Archive</a><a href="#">Calendar</a><a href="#">Contact</a></nav><div class="menu-address">Minneapolis ~ Saint Paul</div><div class="menu-bottom-btns"><button class="menu-btn">Subscribe</button></div></div></div>

<script>
document.querySelectorAll('.acc-trigger').forEach(function(btn){
  btn.addEventListener('click',function(){
    var item=this.parentElement;
    var wasOpen=item.classList.contains('open');
    document.querySelectorAll('.acc-item').forEach(function(i){i.classList.remove('open')});
    if(!wasOpen)item.classList.add('open');
  });
});
var navH=document.getElementById('navHamburger'),menuC=document.getElementById('menuCloseBtn'),menuO=document.getElementById('menuOverlay'),menuP=document.getElementById('menuPanel');
navH.addEventListener('click',function(){menuO.classList.add('open');menuP.classList.add('open');navH.classList.add('open')});
menuC.addEventListener('click',function(){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')});
menuO.addEventListener('click',function(){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')});
document.addEventListener('keydown',function(e){if(e.key==='Escape'){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')}});
</script>
</body>
</html>