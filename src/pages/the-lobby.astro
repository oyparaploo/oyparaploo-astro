---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OyPARáPLoO! — For the love of The English</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
p,h1,h2,h3,h4,li,blockquote{text-wrap:pretty;}
em,i,cite,address,dfn,var{font-style:normal;}
*{font-style:normal;}
html{overflow-x:hidden;scroll-behavior:smooth;font-size:var(--root-size,17px);-webkit-text-size-adjust:100%;text-size-adjust:100%;}
body{font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-wrap:break-word;word-break:break-word;background:var(--ground);color:var(--text-primary);transition:background 0.8s cubic-bezier(0.25,0.46,0.45,0.94),color 0.6s ease;}
a{color:inherit;text-decoration:none;}
a,button,[role="button"],select{touch-action:manipulation;-webkit-tap-highlight-color:transparent;}
button{font-family:inherit;border:none;background:none;cursor:pointer;}
ul,ol{list-style:none;}
img{max-width:100%;height:auto;display:block;}
:root{--oy-radius:4px;--content-width:1200px;--reading-width:700px;--nav-height:64px;--ground:#f0efed;--ground-deep:#0e0e0e;--text-primary:#2a2320;--text-secondary:#3a3028;--text-body:#4a4038;--text-meta:#5a4f47;--text-muted:#8a8078;--accent:#c4956a;--accent-hover:#662a1e;--border:#b8a088;--border-hover:#8a6e50;--card-hover-bg:#faf7f3;--nav-bg:rgba(0,0,0,0.92);--nav-text:rgba(232,224,214,0.68);--nav-text-hover:rgba(232,224,214,0.88);--ground-glow:transparent;}
[data-ground="writing"],[data-ground="methodology"],[data-ground="journey"],[data-ground="essential-ten"],[data-ground="witnesses"],[data-ground="good-grounds"],[data-ground="making"],[data-ground="prayers"],[data-ground="novel"],[data-ground="puppets"],[data-ground="sound"],[data-ground="broadcast"],[data-ground="la-log"],[data-ground="what-persists"],[data-ground="wavelength"],[data-ground="collaboration"]{--ground:#0e0e0e;--text-primary:#d0c8bf;--text-secondary:#ccc5bc;--text-body:#b5ada5;--text-meta:#a09888;--text-muted:#8a8078;--border:#3a3430;--border-hover:#5a5048;--card-hover-bg:#141210;}
[data-ground="writing"]{--accent:#D4A574;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 40% 30%,rgba(212,165,116,0.05) 0%,transparent 55%);}
[data-ground="methodology"]{--accent:#c4956a;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 30% 50%,rgba(196,149,106,0.05) 0%,transparent 50%);}
[data-ground="journey"]{--accent:#a8c8e0;--accent-hover:#b5c8d8;--ground-glow:radial-gradient(ellipse at 60% 20%,rgba(168,200,224,0.06) 0%,transparent 50%);}
[data-ground="essential-ten"]{--accent:#D4A574;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 40% 40%,rgba(212,165,116,0.06) 0%,transparent 50%);}
[data-ground="witnesses"]{--accent:#a8d4b0;--accent-hover:#c8e4d0;--ground-glow:radial-gradient(ellipse at 70% 30%,rgba(168,212,176,0.05) 0%,transparent 50%);}
[data-ground="good-grounds"]{--accent:#B2916C;--accent-hover:#d4b08a;--ground-glow:radial-gradient(ellipse at 50% 50%,rgba(178,145,108,0.07) 0%,transparent 50%);}
[data-ground="making"]{--accent:#6a4a7a;--accent-hover:#8a6a9a;--ground-glow:radial-gradient(ellipse at 40% 60%,rgba(106,74,122,0.06) 0%,transparent 50%);}
[data-ground="portraits"]{--ground:#f9f7f4;--text-primary:#2a2320;--text-secondary:#3a3028;--text-body:#4a4038;--text-meta:#5a4f47;--border:#b8a088;--border-hover:#8a6e50;--card-hover-bg:#faf7f3;--accent:#662a1e;--accent-hover:#573228;--nav-bg:rgba(255,252,248,0.95);--nav-text:rgba(42,35,32,0.68);--nav-text-hover:rgba(42,35,32,0.88);--ground-glow:radial-gradient(ellipse at 30% 20%,rgba(196,149,106,0.04) 0%,transparent 60%);}
[data-ground="prayers"]{--accent:#B2916C;--accent-hover:#d4b08a;--ground-glow:radial-gradient(ellipse at 50% 20%,rgba(178,145,108,0.08) 0%,transparent 50%),radial-gradient(ellipse at 20% 80%,rgba(140,100,60,0.04) 0%,transparent 50%);}
[data-ground="novel"]{--accent:#a8c8e0;--accent-hover:#b5c8d8;--ground-glow:radial-gradient(ellipse at 60% 40%,rgba(168,200,224,0.05) 0%,transparent 50%);}
[data-ground="puppets"]{--accent:#c4956a;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 50% 70%,rgba(196,149,106,0.06) 0%,transparent 50%),radial-gradient(ellipse at 80% 20%,rgba(80,40,20,0.04) 0%,transparent 50%);}
[data-ground="sound"]{--accent:#7a8ea0;--accent-hover:#b5c8d8;--ground-glow:radial-gradient(ellipse at 50% 40%,rgba(122,142,160,0.06) 0%,transparent 55%);}
[data-ground="broadcast"]{--accent:#D4A574;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 60% 30%,rgba(212,165,116,0.05) 0%,transparent 50%);}
[data-ground="la-log"]{--ground:#0a0a0a;--accent:#c4bac4;--accent-hover:#a89eaa;--ground-glow:radial-gradient(ellipse at 50% 30%,rgba(196,186,196,0.04) 0%,transparent 60%);}
[data-ground="what-persists"]{--accent:#a8d4b0;--accent-hover:#c8e4d0;--ground-glow:radial-gradient(ellipse at 30% 50%,rgba(168,212,176,0.05) 0%,transparent 50%);}
[data-ground="wavelength"]{--accent:#a8c8e0;--accent-hover:#b5c8d8;--ground-glow:radial-gradient(ellipse at 50% 50%,rgba(168,200,224,0.05) 0%,transparent 60%);}
[data-ground="collaboration"]{--accent:#c4956a;--accent-hover:#e8e0d8;--ground-glow:radial-gradient(ellipse at 50% 30%,rgba(196,149,106,0.06) 0%,transparent 50%),radial-gradient(ellipse at 80% 70%,rgba(168,200,224,0.04) 0%,transparent 50%);}
body.contrast-mode[data-ground="writing"],body.contrast-mode[data-ground="methodology"],body.contrast-mode[data-ground="journey"],body.contrast-mode[data-ground="essential-ten"],body.contrast-mode[data-ground="witnesses"],body.contrast-mode[data-ground="good-grounds"],body.contrast-mode[data-ground="making"],body.contrast-mode[data-ground="prayers"],body.contrast-mode[data-ground="novel"],body.contrast-mode[data-ground="puppets"],body.contrast-mode[data-ground="sound"],body.contrast-mode[data-ground="broadcast"],body.contrast-mode[data-ground="la-log"],body.contrast-mode[data-ground="what-persists"],body.contrast-mode[data-ground="wavelength"],body.contrast-mode[data-ground="collaboration"]{--ground:#f9f7f4;--text-primary:#2a2320;--text-secondary:#3a3028;--text-body:#4a4038;--text-meta:#5a4f47;--text-muted:#8a8078;--border:#b8a088;--border-hover:#8a6e50;--card-hover-bg:#faf7f3;--nav-bg:rgba(255,252,248,0.95);--nav-text:rgba(42,35,32,0.68);--nav-text-hover:rgba(42,35,32,0.88);}
body.contrast-mode[data-ground="lobby"],body.contrast-mode[data-ground="portraits"]{--ground:#0e0e0e;--text-primary:#d0c8bf;--text-secondary:#ccc5bc;--text-body:#b5ada5;--text-meta:#a09888;--text-muted:#8a8078;--border:#3a3430;--border-hover:#5a5048;--card-hover-bg:#141210;--nav-bg:rgba(0,0,0,0.92);--nav-text:rgba(232,224,214,0.68);--nav-text-hover:rgba(232,224,214,0.88);}
body.contrast-mode[data-ground="lobby"] .lobby-header{background:#0e0e0e;}
body.contrast-mode[data-ground="lobby"] .logotype{background:linear-gradient(135deg,#d0c8bf 0%,#b5ada5 50%,#a09888 100%);-webkit-background-clip:text;background-clip:text;}
body.contrast-mode[data-ground="lobby"] .lobby-tagline{color:#b5ada5;}
body.contrast-mode[data-ground="lobby"] .lobby-sub{color:#b5ada5;}
body.contrast-mode[data-ground="lobby"] .editorial{background:linear-gradient(to bottom,#0e0e0e 0%,#f0efed 8%,#f0efed 100%);}
body.contrast-mode[data-ground="la-log"] .ground-title{background:linear-gradient(135deg,#5a4f47 0%,#4a4038 30%,#5a4f47 60%,#3a3028 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
body.contrast-mode[data-ground="portraits"] .ground-eyebrow{color:#D4A574;}
html.size-1{--root-size:17px;}html.size-2{--root-size:18px;}html.size-3{--root-size:20px;}
.font-size-btn{display:flex;gap:2px;font-weight:600;align-items:baseline;}
.font-size-btn .sz{color:var(--nav-text) !important;opacity:1;transition:opacity 0.25s,color 0.6s;line-height:1;}
.font-size-btn .sz.active{opacity:1;}
.font-size-btn .sz[data-size="1"]{font-size:22px;}.font-size-btn .sz[data-size="2"]{font-size:18px;}.font-size-btn .sz[data-size="3"]{font-size:15px;}
.site-nav{position:sticky;top:0;z-index:100;background:var(--nav-bg);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);transition:background 0.6s ease;}
.nav-inner{max-width:1400px;margin:0 auto;padding:0 40px;height:64px;display:flex;align-items:center;}
.wordmark{font-family:'Inter',sans-serif;font-weight:500;font-size:22px;color:var(--nav-text);letter-spacing:0.02em;flex-shrink:0;transition:color 0.4s;cursor:pointer;}
.wordmark:hover{color:var(--nav-text-hover);}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none;padding-left:0;margin-left:48px;flex-shrink:0;}
.nav-links a{font-family:'Inter',sans-serif;font-size:21px;font-weight:500;letter-spacing:0.02em;color:var(--nav-text);transition:color 0.4s;white-space:nowrap;}
.nav-links a:hover{color:var(--nav-text-hover);}
.nav-utils{display:flex;align-items:center;gap:12px;margin-left:auto;}
.nav-utils button,.nav-utils a{font-family:'Inter',sans-serif;color:var(--nav-text);background:none;border:none;cursor:pointer;min-height:44px;padding:0 8px;display:flex;align-items:center;justify-content:center;transition:color 0.4s;}
.nav-utils button:hover,.nav-utils a:hover{color:var(--nav-text-hover);}
.nav-utils svg{stroke:currentColor;fill:none;}
.nav-hamburger{display:flex;flex-direction:column;justify-content:center;align-items:center;gap:5px;min-height:44px;padding:0 8px;}
.nav-hamburger span{display:block;width:22px;height:1.5px;background:var(--nav-text);transition:transform 0.25s,opacity 0.2s,background 0.4s;transform-origin:center;}
.nav-hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);}
.nav-hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.nav-hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);}
.nav-accent-rule{display:block;height:2px;border:none;opacity:0.6;transition:background 0.8s ease;background:linear-gradient(90deg,transparent 0%,rgba(122,90,74,0.35) 8%,rgba(122,90,74,0.55) 15%,rgba(122,90,74,0.28) 24%,rgba(92,58,30,0.45) 34%,rgba(92,58,30,0.65) 44%,rgba(92,58,30,0.28) 54%,rgba(122,90,74,0.50) 63%,rgba(160,128,100,0.40) 74%,rgba(160,128,100,0.28) 83%,rgba(122,90,74,0.30) 90%,transparent 100%);}
.contrast-btn{font-size:20px;line-height:1;letter-spacing:0;}
.nav-ground-indicator{font-family:'Inter',sans-serif;font-size:17px;font-weight:500;color:var(--accent);letter-spacing:0.02em;margin-left:24px;opacity:0;transition:opacity 0.6s ease,color 0.6s ease;white-space:nowrap;}
.nav-ground-indicator.visible{opacity:1;}
.menu-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.50);opacity:0;pointer-events:none;transition:opacity 0.6s;}
.menu-overlay.open{opacity:1;pointer-events:auto;}
.menu-panel{position:fixed;top:0;right:0;bottom:0;z-index:201;width:400px;max-width:90vw;background:#faf6f0;color:#2a2320;font-size:17px;clip-path:inset(16px 20px calc(100% - 68px) calc(100% - 200px) round var(--oy-radius));transition:clip-path 0.6s cubic-bezier(0.4,0,0.1,1),opacity 0.2s ease;overflow-y:auto;padding:24px 32px 40px;pointer-events:none;opacity:0;}
.menu-panel.open{clip-path:inset(0 0 0 0 round 0);pointer-events:auto;opacity:1;}
.menu-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;}
.menu-ghost-wordmark{font-family:'Inter',sans-serif;font-size:22px;font-weight:500;color:#2a2320;opacity:0.38;letter-spacing:0.02em;user-select:none;pointer-events:none;}
.menu-close{width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:22px;color:#2a2320 !important;cursor:pointer;}
.menu-nav-primary a{font-family:'Inter',sans-serif;font-size:18px;font-weight:600;color:#2a2320;display:block;padding:4px 0;line-height:1.2;transition:opacity 0.2s;}
.menu-nav-primary a:hover{opacity:0.55;}
.menu-rule-tan{height:2px;border:none;background:#D4A574;margin:20px 0;}
.menu-rule-sage{height:2px;border:none;background:#8BA89A;margin:20px 0;}
.menu-nav-secondary a,.menu-nav-tertiary a{font-family:'Inter',sans-serif;font-size:18px;font-weight:600;color:#2a2320;display:block;padding:4px 0;transition:opacity 0.2s;}
.menu-nav-secondary a:hover,.menu-nav-tertiary a:hover{opacity:0.55;}
.menu-address{font-family:'Inter',sans-serif;font-size:19px;font-weight:500;color:#5a4f47;margin-top:20px;line-height:1.6;}
.menu-bottom-btns{display:flex;gap:8px;margin-top:20px;}
.menu-bottom-btns .menu-btn{font-family:'Inter',sans-serif;font-size:16px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:#2a2320;border:1px solid rgba(42,35,32,0.40);padding:8px 16px;border-radius:var(--oy-radius);background:transparent;cursor:pointer;transition:background 0.2s,color 0.2s,border-color 0.2s;min-height:44px;}
.menu-bottom-btns .menu-btn:hover{background:#2a2320;color:#faf8f5;border-color:#2a2320;}
.threshold{position:fixed;inset:0;z-index:300;pointer-events:none;opacity:0;transition:opacity 0.3s ease;}
.threshold.active{opacity:1;}
.threshold-curtain{position:absolute;inset:0;background:var(--ground-deep,#0e0e0e);transform:scaleY(0);transform-origin:bottom;transition:transform 0.5s cubic-bezier(0.7,0,0.3,1);}
.threshold.active .threshold-curtain{transform:scaleY(1);}
.threshold.exit .threshold-curtain{transform-origin:top;transform:scaleY(0);transition:transform 0.5s cubic-bezier(0.7,0,0.3,1) 0.1s;}
.ground-container{min-height:calc(100vh - var(--nav-height) - 2px);position:relative;}
.ground-container::before{content:'';position:absolute;inset:0;background:var(--ground-glow);pointer-events:none;transition:background 1.2s ease;}
.ground{display:none;animation:ground-arrive 0.8s ease forwards;}
.ground.active{display:block;}
@keyframes ground-arrive{from{opacity:0;}to{opacity:1;}}
.lobby-header{padding:80px 64px 48px;background:#f0efed;text-align:left;}
.lobby-header-inner{max-width:1200px;margin:0 auto;}
.logotype{font-family:'Lora',serif;font-size:clamp(36px,5.5vw,64px);font-weight:700;letter-spacing:0.03em;line-height:1.15;padding-bottom:0.15em;background:linear-gradient(135deg,#662a1e 0%,#573228 50%,#44403f 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px;opacity:0;animation:logotype-arrive 1.8s cubic-bezier(0.25,0.46,0.45,0.94) 0.3s forwards;}
@keyframes logotype-arrive{from{opacity:0;letter-spacing:0.08em;}to{opacity:1;letter-spacing:0.03em;}}
.lobby-tagline{font-family:'Lora',serif;font-size:clamp(18px,2.2vw,24px);font-weight:600;color:#573228;letter-spacing:0.02em;margin-bottom:12px;line-height:1.3;opacity:0;animation:fade-in 1.4s ease 0.9s forwards;}
.lobby-sub{font-size:1.0588rem;font-weight:450;line-height:1.7;color:#4a4038;max-width:480px;opacity:0;animation:fade-in 1.4s ease 1.2s forwards;}
@keyframes fade-in{from{opacity:0;}to{opacity:1;}}
.editorial{background:linear-gradient(to bottom,#f0efed 0%,#0e0e0e 8%,#0e0e0e 100%);}
.ed-hero{position:relative;cursor:pointer;min-height:500px;display:flex;align-items:flex-end;overflow:hidden;}
.ed-hero-image{position:absolute;inset:0;}
.ed-hero-image svg,.ed-hero-image img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 1.4s cubic-bezier(0.25,0.1,0.25,1);}
.ed-hero:hover .ed-hero-image svg,.ed-hero:hover .ed-hero-image img{transform:scale(1.03);}
.ed-hero::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.7) 0%,rgba(0,0,0,0.1) 50%,transparent 100%);pointer-events:none;}
.ed-hero-text{position:relative;z-index:2;padding:0 64px 64px;max-width:620px;}
.ed-hero.ed-hero-text-left .ed-hero-text{margin-right:auto;}
.ed-label{font-size:0.8235rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#a09888;margin-bottom:16px;}
.ed-title{font-family:'Lora',serif;font-size:clamp(1.647rem,3.5vw,2.353rem);font-weight:700;color:#e8e0d8;line-height:1.2;margin-bottom:16px;}
.ed-excerpt{font-size:1.0588rem;font-weight:400;line-height:1.75;color:#b5ada5;margin-bottom:20px;}
.ed-cta{font-size:0.8824rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;color:#d0c8bf;padding-bottom:2px;border-bottom:1px solid #5a5048;transition:color 0.3s,border-color 0.3s;}
.ed-hero:hover .ed-cta{color:#e8e0d8;border-color:#8a6e50;}
.ed-row{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
.ed-row-2{grid-template-columns:repeat(2,1fr);}
.ed-card{padding:0;cursor:pointer;background:#0e0e0e;transition:background 0.4s;overflow:hidden;}
.ed-card:hover{background:#141210;}
.ed-card-image{width:100%;aspect-ratio:3/2;overflow:hidden;}
.ed-card-image svg,.ed-card-image img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 1.2s cubic-bezier(0.25,0.1,0.25,1);}
.ed-card:hover .ed-card-image svg,.ed-card:hover .ed-card-image img{transform:scale(1.04);}
.ed-card .ed-label{padding:24px 28px 0;}
.ed-card-title{font-family:'Lora',serif;font-size:1.2353rem;font-weight:600;color:#ccc5bc;line-height:1.25;padding:8px 28px 0;transition:color 0.3s;}
.ed-card:hover .ed-card-title{color:#e8e0d8;}
.ed-card-desc{font-size:0.9412rem;font-weight:400;color:#a09888;line-height:1.6;padding:8px 28px 28px;}
.lobby-browse{padding:100px 64px 120px;background:#0e0e0e;}
.lobby-browse-inner{max-width:1200px;margin:0 auto;}
.lobby-browse-title{font-family:'Lora',serif;font-size:clamp(1.294rem,2.5vw,1.647rem);font-weight:600;color:#d0c8bf;margin-bottom:40px;}
.lobby-browse-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;}
.browse-link{display:flex;justify-content:space-between;align-items:baseline;padding:16px 0;border-bottom:1px solid #2a2520;transition:border-color 0.3s;margin:0 24px 0 0;cursor:pointer;}
.browse-link:hover{border-color:#5a5048;}
.browse-name{font-size:1.0588rem;font-weight:600;color:#ccc5bc;transition:color 0.3s;}
.browse-link:hover .browse-name{color:#e8e0d8;}
.browse-count{font-size:0.8824rem;font-weight:500;color:#8a8078;letter-spacing:0.02em;white-space:nowrap;margin-left:16px;}
.ground-interior{padding:80px 32px 120px;}
.ground-interior-inner{max-width:var(--content-width);margin:0 auto;}
.ground-eyebrow{font-size:1rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--accent);margin-bottom:32px;}
.ground-entrance-name{font-size:0.9412rem;font-weight:500;color:var(--text-meta);letter-spacing:0.01em;margin-bottom:12px;line-height:1.4;}
.ground-title{font-family:'Lora',serif;font-size:clamp(1.882rem,5vw,3.059rem);font-weight:700;line-height:1.15;color:var(--text-primary);margin-bottom:24px;}
.ground-intro{font-size:1.0588rem;font-weight:400;line-height:1.85;color:var(--text-body);max-width:620px;margin-bottom:64px;}
.ground-divider{height:1px;border:none;background:var(--border);margin:48px 0;transition:background 0.6s;}
.ground-back{display:inline-flex;align-items:center;gap:8px;font-size:1rem;font-weight:500;color:var(--text-meta);letter-spacing:0.02em;margin-bottom:40px;transition:color 0.3s;cursor:pointer;}
.ground-back:hover{color:var(--text-primary);}
.ground-back svg{width:18px;height:18px;stroke:currentColor;fill:none;}
.reveal{opacity:0;transition:opacity 1.2s ease;}
.reveal.visible{opacity:1;}
.reveal-delay-1{transition-delay:0.12s;}.reveal-delay-2{transition-delay:0.24s;}.reveal-delay-3{transition-delay:0.36s;}.reveal-delay-4{transition-delay:0.48s;}.reveal-delay-5{transition-delay:0.60s;}.reveal-delay-6{transition-delay:0.72s;}
.bottom-safe{padding-bottom:env(safe-area-inset-bottom,0px);}
