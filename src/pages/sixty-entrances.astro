---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sixty Entrances — Oyparaploo</title>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
p, h1, h2, h3, h4, li, blockquote { text-wrap: pretty; }
em, i, cite, address, dfn, var { font-style: normal; }
* { font-style: normal; }
html { overflow-x: hidden; scroll-behavior: smooth; font-size: var(--root-size, 17px); -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
body { font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; overflow-x: hidden; overflow-wrap: break-word; word-break: break-word; background: #ffffff; min-height: 100vh; color: #2a2320; }
a { color: inherit; text-decoration: none; }
a, button, [role="button"], select { touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
button { font-family: inherit; border: none; background: none; cursor: pointer; }
ul, ol { list-style: none; }
img { max-width: 100%; height: auto; display: block; }
:root { --oy-radius: 4px; --max-w: 1140px; --accent-red: #9e3a2a; --accent-red-hover: #7a2a1e; }
html.size-1 { --root-size: 17px; } html.size-2 { --root-size: 18px; } html.size-3 { --root-size: 20px; }
.font-size-btn { display: flex; gap: 2px; font-weight: 600; align-items: baseline; }
.font-size-btn .sz { color: #000 !important; opacity: 1; transition: opacity 0.25s; line-height: 1; }
.font-size-btn .sz.active { opacity: 1; }
.font-size-btn .sz[data-size="1"] { font-size: 22px; } .font-size-btn .sz[data-size="2"] { font-size: 18px; } .font-size-btn .sz[data-size="3"] { font-size: 15px; }
.site-nav { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.97); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px); border-bottom: 1px solid #e0d8d0; }
.nav-inner { max-width: 1400px; margin: 0 auto; padding: 0 48px; height: 56px; display: flex; align-items: center; }
.wordmark { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 22px; color: #2a2320; letter-spacing: 0.02em; flex-shrink: 0; transition: color 0.2s; text-decoration: none; }
.wordmark:hover { color: #5c3a1e; }
.nav-links { display: flex; align-items: center; gap: 24px; list-style: none; padding-left: 0; margin-left: 48px; flex-shrink: 0; }
.nav-links a { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; letter-spacing: 0.02em; color: #5a4f47; transition: color 0.2s; white-space: nowrap; }
.nav-links a:hover { color: #2a2320; }
.nav-utils { display: flex; align-items: center; gap: 12px; margin-left: auto; }
.nav-utils button, .nav-utils a { font-family: 'Inter', sans-serif; color: #2a2320; background: none; border: none; cursor: pointer; min-height: 44px; padding: 0 8px; display: flex; align-items: center; justify-content: center; transition: color 0.2s; }
.nav-utils button:hover, .nav-utils a:hover { color: #5c3a1e; }
.nav-utils svg { stroke: currentColor; fill: none; }
.nav-hamburger { display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 5px; min-height: 44px; padding: 0 8px; }
.nav-hamburger span { display: block; width: 22px; height: 1.5px; background: #2a2320; transition: transform 0.25s, opacity 0.2s; transform-origin: center; }
.nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.nav-accent-rule { display: block; height: 3px; border: none; background: linear-gradient(to right, #a8c8e0 0%, #a8c8e0 70%, #a8d4b0 100%); }
.menu-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.45); opacity: 0; pointer-events: none; transition: opacity 0.6s; }
.menu-overlay.open { opacity: 1; pointer-events: auto; }
.menu-strips { position: fixed; top: 0; bottom: 0; left: 0; right: 400px; z-index: 201; display: flex; flex-direction: row; overflow: hidden; opacity: 0; transition: opacity 0.5s ease 0.15s; pointer-events: none; }
.menu-strips.open { opacity: 1; pointer-events: auto; }
.strip { flex: 1; position: relative; overflow: hidden; cursor: pointer; transition: flex 1.2s cubic-bezier(0.25,0.1,0.25,1); min-width: 0; }
.strip:hover { flex: 4; }
.strip-bg { position: absolute; inset: 0; transition: transform 1.4s cubic-bezier(0.25,0.1,0.25,1); }
.strip::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 30%; z-index: 1; background: linear-gradient(to top, rgba(0,0,0,0.28) 0%, transparent 100%); pointer-events: none; }
.strip:hover .strip-bg { transform: scale(1.04); }
.strip-bottom { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.4); -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px); padding: 40px 36px 44px; z-index: 2; opacity: 0; transition: opacity 0.8s ease 0.3s; }
.strip:hover .strip-bottom { opacity: 1; }
.strip-content { color: #fff; }
.strip-title { font-family: 'Inter', sans-serif; font-size: 34px; font-weight: 700; line-height: 1.12; margin-bottom: 8px; }
.strip-subtitle { font-family: 'Lora', serif; font-size: 26px; font-weight: 500; color: rgba(255,255,255,0.9); line-height: 1.25; margin-bottom: 14px; }
.strip-buttons { display: flex; gap: 12px; flex-wrap: wrap; }
.strip-btn { display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 500; color: #fff; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.75); background: rgba(255,255,255,0.28); -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); letter-spacing: 0.01em; transition: all 0.3s; }
.strip-btn:hover { background: rgba(255,255,255,0.40); border-color: #fff; }
.strip-1 .strip-bg { background: linear-gradient(160deg, #c9bcac 0%, #8a7a6a 100%); }
.strip-2 .strip-bg { background: linear-gradient(160deg, #8BA89A 0%, #5a7a6a 100%); }
.strip-3 .strip-bg { background: linear-gradient(160deg, #D4A574 0%, #a07050 100%); }
.strip-4 .strip-bg { background: linear-gradient(160deg, #7a8aaa 0%, #4a5a7a 100%); }
.mobile-strips { display: none; gap: 10px; margin-bottom: 24px; overflow-x: auto; scrollbar-width: none; }
.mobile-strips::-webkit-scrollbar { display: none; }
.mobile-strip-card { flex: 0 0 140px; height: 100px; border-radius: var(--oy-radius); position: relative; overflow: hidden; cursor: pointer; border: 1px solid rgba(0,0,0,0.28); }
.mobile-strip-card .strip-bg { position: absolute; inset: 0; border-radius: var(--oy-radius); }
.mobile-strip-card::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%); border-radius: var(--oy-radius); }
.mobile-strip-card-text { position: absolute; bottom: 10px; left: 12px; right: 8px; z-index: 2; color: #fff; }
.mobile-strip-card-title { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; line-height: 1.2; margin-bottom: 2px; }
.mobile-strip-card-sub { font-family: 'Lora', serif; font-size: 17px; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.2; }
.menu-panel { position: fixed; top: 0; right: 0; bottom: 0; z-index: 201; width: 400px; max-width: 90vw; background: #faf6f0; color: #2a2320; font-size: 17px; clip-path: inset(16px 20px calc(100% - 68px) calc(100% - 200px) round var(--oy-radius)); transition: clip-path 0.6s cubic-bezier(0.4,0,0.1,1), opacity 0.2s ease; overflow-y: auto; padding: 24px 32px 40px; pointer-events: none; opacity: 0; }
.menu-panel.open { clip-path: inset(0 0 0 0 round 0); pointer-events: auto; opacity: 1; }
.menu-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
.menu-ghost-wordmark { font-family: 'Inter', sans-serif; font-size: 22px; font-weight: 500; color: #2a2320; opacity: 0.38; }
.menu-close { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: #2a2320 !important; cursor: pointer; }
.menu-nav-primary a { font-family: 'Lora', serif; font-size: 24px; font-weight: 600; color: #2a2320; display: block; padding: 10px 0; transition: opacity 0.2s; }
.menu-nav-primary a:hover { opacity: 0.55; }
.menu-rule-tan { height: 2px; border: none; background: #D4A574; margin: 20px 0; }
.menu-rule-sage { height: 2px; border: none; background: #8BA89A; margin: 20px 0; }
.menu-nav-secondary a, .menu-nav-tertiary a { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 600; color: #2a2320; display: block; padding: 4px 0; transition: opacity 0.2s; }
.menu-address { font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 500; color: #5a4f47; margin-top: 20px; }
.menu-bottom-btns { display: flex; gap: 8px; margin-top: 20px; }
.menu-bottom-btns .menu-btn { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: #2a2320; border: 1px solid rgba(42,35,32,0.40); padding: 8px 16px; border-radius: var(--oy-radius); background: transparent; cursor: pointer; min-height: 44px; }
.reveal { opacity: 0; transition: opacity 1.2s ease; }
.reveal.visible { opacity: 1; }
.tabs { display: flex; padding: 0 48px; border-bottom: 1px solid #e0d8d0; background: #fff; }
.tabs a { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; color: #b8a088; padding: 14px 20px 13px; border-bottom: 2px solid transparent; transition: all 0.2s; }
.tabs a:hover { color: #5a4f47; }
.tabs a.on { color: #2a2320; border-bottom-color: #2a2320; }
.page-header { max-width: var(--max-w); margin: 0 auto; padding: 64px 48px 0; }
.page-label { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #b8a088; margin-bottom: 12px; }
.page-title { font-family: 'Lora', serif; font-size: clamp(36px, 5vw, 56px); font-weight: 700; color: #2a2320; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 16px; }
.page-subtitle { font-family: 'Inter', sans-serif; font-size: 1.1rem; font-weight: 400; color: #5a4f47; line-height: 1.7; max-width: 640px; }
.page-rule { height: 1px; background: #e0d8d0; margin: 48px 0 0; }
.sec { max-width: var(--max-w); margin: 0 auto; padding: 48px 48px 0; }
.sec-title { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #b8a088; margin-bottom: 32px; }
.sec-count { font-weight: 500; color: #5a4f47; margin-left: 8px; text-transform: none; letter-spacing: 0; }
.ground-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; margin-bottom: 48px; }
.ground-card { display: block; position: relative; padding: 28px; border: 1px solid #e0d8d0; transition: border-color 0.3s, background 0.3s; cursor: pointer; }
.ground-card:hover { border-color: #8a6e50; background: #faf7f3; }
.ground-number { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #fff; background: #2a2320; display: inline-block; padding: 3px 10px; margin-bottom: 14px; }
.ground-label { font-family: 'Lora', serif; font-size: clamp(22px, 2vw, 28px); font-weight: 700; color: #2a2320; letter-spacing: -0.01em; line-height: 1.2; margin-bottom: 8px; transition: color 0.2s; }
.ground-card:hover .ground-label { color: #000; }
.ground-entrance { font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 400; color: #5a4f47; line-height: 1.5; }
.ground-accent { position: absolute; top: 0; left: 0; width: 4px; height: 100%; }
.pill-field { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 64px; }
.pill { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 500; color: #5a4f47; padding: 10px 20px; border: 1px solid #e0d8d0; transition: all 0.3s; cursor: pointer; display: inline-flex; align-items: center; gap: 8px; }
.pill:hover { border-color: #8a6e50; color: #2a2320; background: #faf7f3; }
.pill-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.tagline-section { max-width: var(--max-w); margin: 0 auto; padding: 64px 48px 80px; border-top: 1px solid #e0d8d0; }
.tagline-eyebrow { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #b8a088; margin-bottom: 20px; }
.tagline-text { font-family: 'Lora', serif; font-size: clamp(24px, 3vw, 36px); font-weight: 600; color: #2a2320; line-height: 1.35; max-width: 700px; letter-spacing: -0.01em; }
.tagline-sub { font-family: 'Inter', sans-serif; font-size: 1rem; font-weight: 400; color: #5a4f47; line-height: 1.7; max-width: 560px; margin-top: 20px; }
.site-footer { background: #1a1816; padding: 64px 48px 40px; }
.footer-inner { max-width: var(--max-w); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 48px; }
.footer-col-title { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #d4c4b0; margin-bottom: 16px; }
.footer-col a, .footer-col p { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 400; color: #999; display: block; padding: 4px 0; transition: color 0.2s; line-height: 1.5; }
.footer-col a:hover { color: #d4c4b0; }
.footer-bottom { max-width: var(--max-w); margin: 40px auto 0; padding-top: 24px; border-top: 1px solid #333; font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 400; color: #666; }
body.dark-mode { background: linear-gradient(to bottom, #000000 0%, #0d111b 100%); background-attachment: fixed; color: #d0c8bf; }
body.dark-mode .site-nav { background: rgba(0,0,0,0.92); border-bottom-color: transparent; }
body.dark-mode .wordmark { color: rgba(232,224,214,0.68); }
body.dark-mode .wordmark:hover { color: rgba(232,224,214,0.88); }
body.dark-mode .nav-links a { color: rgba(232,224,214,0.68); }
body.dark-mode .nav-links a:hover { color: rgba(232,224,214,0.88); }
body.dark-mode .nav-utils button, body.dark-mode .nav-utils a { color: rgba(232,224,214,0.68); }
body.dark-mode .nav-hamburger span { background: rgba(232,224,214,0.68); }
body.dark-mode .font-size-btn .sz { color: rgba(232,224,214,0.68) !important; }
body.dark-mode .tabs { background: rgba(0,0,0,0.6); border-bottom-color: #3a3430; }
body.dark-mode .tabs a { color: #8a8078; }
body.dark-mode .tabs a:hover { color: #b5ada5; }
body.dark-mode .tabs a.on { color: #d0c8bf; border-bottom-color: #d0c8bf; }
body.dark-mode .page-label { color: #8a8078; }
body.dark-mode .page-title { color: #d0c8bf; }
body.dark-mode .page-subtitle { color: #b5ada5; }
body.dark-mode .page-rule { background: #3a3430; }
body.dark-mode .sec-title { color: #8a8078; }
body.dark-mode .sec-count { color: #b5ada5; }
body.dark-mode .ground-card { border-color: #3a3430; }
body.dark-mode .ground-card:hover { border-color: #5a5048; background: #141210; }
body.dark-mode .ground-number { background: #d0c8bf; color: #0e0e0e; }
body.dark-mode .ground-label { color: #ccc5bc; }
body.dark-mode .ground-card:hover .ground-label { color: #e8e0d8; }
body.dark-mode .ground-entrance { color: #b5ada5; }
body.dark-mode .pill { color: #b5ada5; border-color: #3a3430; }
body.dark-mode .pill:hover { color: #d0c8bf; border-color: #5a5048; background: #141210; }
body.dark-mode .tagline-section { border-top-color: #3a3430; }
body.dark-mode .tagline-eyebrow { color: #8a8078; }
body.dark-mode .tagline-text { color: #d0c8bf; }
body.dark-mode .tagline-sub { color: #b5ada5; }
@media (max-width: 1100px) { .nav-links { display: none; } }
@media (max-width: 768px) { .nav-inner { padding: 0 24px; } .menu-strips { display: none; } .mobile-strips { display: flex; } .menu-panel { width: 100%; max-width: 100%; } .reveal { transition: opacity 0.6s ease; } .tabs { padding: 0 24px; overflow-x: auto; scrollbar-width: none; } .tabs::-webkit-scrollbar { display: none; } .tabs a { white-space: nowrap; } .page-header { padding: 40px 24px 0; } .sec { padding: 40px 24px 0; } .ground-grid { grid-template-columns: 1fr; } .tagline-section { padding: 48px 24px 64px; } .site-footer { padding: 48px 24px 32px; } .footer-inner { grid-template-columns: 1fr; gap: 32px; } }
</style>
</head>
