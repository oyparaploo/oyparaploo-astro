---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oyparaploo — Cookie Consent</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --dw-yellow: #ffcc00;
    --dw-yellow-h: #e6b800;
    --m-bg: #1a1a2e;
    --m-text: #ffffff;
    --m-body: #e0e0e0;
    --m-muted: #aaa;
    --m-rule: #444;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    background: #0e0e0e;
    color: #fff;
    min-height: 100vh;
    overflow: hidden;
    -webkit-text-size-adjust: 100%;
  }

  .page-bg {
    position: fixed; inset: 0;
    background: linear-gradient(to bottom, #000 0%, #111521 100%);
    background-attachment: fixed;
  }

  .c-overlay {
    position: fixed; inset: 0;
    background: rgba(5, 10, 20, 0.60);
    z-index: 9000;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.25s ease;
  }
  .c-overlay.off { opacity: 0; pointer-events: none; }

  .c-modal {
    background: var(--m-bg);
    width: 640px;
    max-width: 94vw;
    max-height: 82vh;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 24px rgba(0,0,0,0.4);
    border-radius: 3px;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }

  .c-scroll {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 32px 36px 12px;
    min-height: 0;
  }
  .c-scroll::-webkit-scrollbar { width: 8px; }
  .c-scroll::-webkit-scrollbar-track { background: #2a2a3e; }
  .c-scroll::-webkit-scrollbar-thumb { background: #555; }
  .c-scroll::-webkit-scrollbar-thumb:hover { background: #777; }
  .c-scroll { scrollbar-width: thin; scrollbar-color: #555 #2a2a3e; }

  .c-wordmark { margin-bottom: 18px; }
  .c-wordmark img { height: 28px; width: auto; filter: invert(1); opacity: 0.7; }

  .v-main {}
  .v-main.hide { display: none; }

  .c-title {
    font-size: 24px;
    font-weight: 500;
    color: var(--m-text);
    margin-bottom: 20px;
    line-height: 1.3;
    letter-spacing: 0.01em;
  }

  .c-prose {
    font-size: 16px;
    line-height: 1.65;
    color: var(--m-body);
    font-weight: 450;
  }
  .c-prose p { margin-bottom: 16px; }
  .c-prose p:last-child { margin-bottom: 4px; }
  .c-prose a {
    color: var(--m-body);
    text-decoration: underline;
    text-underline-offset: 2px;
    cursor: pointer;
  }
  .c-prose a.bold-link { font-weight: 500; color: var(--m-text); }
  .c-prose em { font-style: normal; color: var(--m-muted); }

  .v-settings { display: none; }
  .v-settings.show { display: block; }

  .v-settings-intro {
    font-size: 16px;
    line-height: 1.65;
    color: var(--m-body);
    font-weight: 450;
    margin-bottom: 6px;
  }

  .dd { border-bottom: none; }
  .dd-head {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; padding: 14px 0; border: none; background: none;
    cursor: pointer; text-align: left; font-family: inherit;
    -webkit-tap-highlight-color: transparent;
  }
  .dd-head:focus-visible { outline: 2px solid var(--dw-yellow); outline-offset: 2px; border-radius: 2px; }
  .dd-name { font-size: 18px; font-weight: 500; color: var(--m-text); line-height: 1.3; letter-spacing: 0.02em; }
  .dd-chev { width: 24px; height: 24px; flex-shrink: 0; margin-left: 12px; transition: transform 0.25s ease; color: #ffffff; }
  .dd-chev polyline { stroke-width: 1.8; }
  .dd.open .dd-chev { transform: rotate(180deg); }
  .dd-body { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .dd.open .dd-body { max-height: 600px; }
  .dd-body-inner { padding: 2px 0 16px; }
  .dd-body-inner p { font-size: 16px; line-height: 1.65; color: var(--m-body); font-weight: 450; margin-bottom: 10px; }
  .dd-body-inner p:last-child { margin-bottom: 0; }

  .c-foot {
    flex-shrink: 0; padding: 32px 36px 24px; background: var(--m-bg);
    border-top: 1px solid rgba(255,255,255,0.25);
  }
  .c-foot-rule { height: 1px; background: var(--m-rule); margin-bottom: 18px; }
  .c-btns { display: flex; justify-content: center; gap: 12px; margin-bottom: 28px; }
  .c-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 11px 24px; border-radius: 3px; font-size: 16px;
    font-weight: 650; cursor: pointer; font-family: inherit;
    line-height: 1; letter-spacing: 0.03em;
    transition: background 0.12s ease;
  }
  .c-btn svg { width: 13px; height: 13px; stroke-width: 3; }
  .c-btn-y { background: var(--dw-yellow); color: #000; border: none; }
  .c-btn-y:hover { background: var(--dw-yellow-h); }

  .c-links { display: flex; align-items: center; justify-content: center; }
  .c-links a { font-size: 14px; font-weight: 500; color: var(--m-body); text-decoration: none; cursor: pointer; letter-spacing: 0.03em; }
  .c-links a:hover { text-decoration: underline; }
  .c-links .pip { margin: 0 8px; color: var(--m-muted); font-weight: 400; font-size: 15px; }

  @media (max-width: 600px) {
    .c-scroll { padding: 24px 20px 8px; }
    .c-foot { padding: 0 20px 20px; }
    .c-title { font-size: 20px; }
    .dd-name { font-size: 16px; }
    .c-btns { flex-direction: column; }
    .c-btn { justify-content: center; width: 100%; }
  }
</style>
</head>
<body>

<div class="page-bg"></div>

<div class="c-overlay" id="ov">
  <div class="c-modal" role="dialog" aria-modal="true" aria-labelledby="ct">

    <div class="c-scroll" id="sc">

      <div class="v-main" id="v1">
        <h2 class="c-title" id="ct">We don't collect your data.</h2>
        <div class="c-prose">
          <p>We are a small organization based in Minneapolis and Saint Paul. This site doesn't track you, profile you, or sell anything having to do with your visit. If you give us your email, we keep it for only the newsletter. That's it.</p>
          <p style="margin-top: 12px;"><a href="javascript:void(0)" id="lnkS" style="text-underline-offset: 7px; text-decoration-thickness: 1px;">More Details</a></p>
        </div>
      </div>

      <div class="v-settings" id="v2">

        <div class="dd" data-dd>
          <button class="dd-head" aria-expanded="false">
            <span class="dd-name">What happens when you browse our website</span>
            <svg class="dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 10 12 16 20 10"/></svg>
          </button>
          <div class="dd-body"><div class="dd-body-inner">
            <p>Nothing much. The site is static HTML files hosted on GitHub Pages. There's no mechanism to track you. We don't run Google Analytics or any tracking scripts. No pixels. No fingerprinting. No heat maps of where your eyes went. The pages load and they're yours alone.</p>
          </div></div>
        </div>

        <div class="dd" data-dd>
          <button class="dd-head" aria-expanded="false">
            <span class="dd-name">Audio and video from other platforms</span>
            <svg class="dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 10 12 16 20 10"/></svg>
          </button>
          <div class="dd-body"><div class="dd-body-inner">
            <p>Some pages embed audio players from SoundCloud, Bandcamp, or videos from YouTube or Vimeo. When these embeds load, those companies can set their own cookies and collect data about your visit. We can't control what they do on their end. If this concerns you, most browsers let you block third-party cookies. The writing and images on the site will work the same way regardless.</p>
          </div></div>
        </div>

        <div class="dd" data-dd>
          <button class="dd-head" aria-expanded="false">
            <span class="dd-name">If you share your email with us</span>
            <svg class="dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 10 12 16 20 10"/></svg>
          </button>
          <div class="dd-body"><div class="dd-body-inner">
            <p>Our newsletter asks for your email address and our contact form asks for your name and email. We don't sell or share any email list. Also, you can unsubscribe at any time and we'll remove your information. "Personal data" means something you wanted us to have, to receive our free resources.</p>
          </div></div>
        </div>

        <div class="dd" data-dd>
          <button class="dd-head" aria-expanded="false">
            <span class="dd-name">Our site doesn't have cookies</span>
            <svg class="dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 10 12 16 20 10"/></svg>
          </button>
          <div class="dd-body"><div class="dd-body-inner">
            <p>Static HTML files on GitHub Pages have no mechanism to set cookies. If you see one, it came from an embedded player or an external service. Not from us.</p>
          </div></div>
        </div>

        <div class="dd" data-dd>
          <button class="dd-head" aria-expanded="false">
            <span class="dd-name">Future possibilities regarding this</span>
            <svg class="dd-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 10 12 16 20 10"/></svg>
          </button>
          <div class="dd-body"><div class="dd-body-inner">
            <p>We might add privacy-focused analytics like Plausible, which counts page views without cookies or personal data. Advertising may at some point appear on some of the pages. This notice will change if it happens.</p>
          </div></div>
        </div>

      </div>
    </div>

    <div class="c-foot">
      <div class="c-btns">
        <button class="c-btn c-btn-y" id="bA">
          Got it
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
      <div class="c-links">
        <a href="javascript:void(0)" id="fS">Settings</a>
        <span class="pip">|</span>
        <a href="/privacy-policy">Privacy Policy</a>
        <span class="pip">|</span>
        <a href="/legal-notice">Legal Notice</a>
      </div>
    </div>

  </div>
</div>

<script>
  const ov = document.getElementById('ov');
  const sc = document.getElementById('sc');
  const v1 = document.getElementById('v1');
  const v2 = document.getElementById('v2');

  function toSettings(e) { e.preventDefault(); v1.classList.add('hide'); v2.classList.add('show'); sc.scrollTop = 0; }
  function toMain(e) { e.preventDefault(); v2.classList.remove('show'); v1.classList.remove('hide'); sc.scrollTop = 0; }

  document.getElementById('lnkS').addEventListener('click', toSettings);
  document.getElementById('fS').addEventListener('click', (e) => {
    v2.classList.contains('show') ? toMain(e) : toSettings(e);
  });

  document.querySelectorAll('[data-dd]').forEach(dd => {
    dd.querySelector('.dd-head').addEventListener('click', () => {
      const open = dd.classList.toggle('open');
      dd.querySelector('.dd-head').setAttribute('aria-expanded', open);
    });
  });

  document.getElementById('bA').addEventListener('click', () => ov.classList.add('off'));
</script>

</body>
</html>