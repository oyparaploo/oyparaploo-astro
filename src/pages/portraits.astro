---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Portraits — Oyparaploo</title>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
p, h1, h2, h3, h4, li, blockquote { text-wrap: pretty; }
em, i, cite, address, dfn, var { font-style: normal; }
* { font-style: normal; }
a, a:hover, a:visited, a:active, a:focus { color: inherit; text-decoration: none; }
a, button, [role="button"], select { touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
button { font-family: inherit; border: none; background: none; cursor: pointer; }
ul, ol { list-style: none; }
img { max-width: 100%; height: auto; display: block; }
html { overflow-x: hidden; scroll-behavior: smooth; font-size: var(--root-size, 17px); -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
body { font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; overflow-x: hidden; overflow-wrap: break-word; word-break: break-word; transition: background 0.4s ease, color 0.3s ease; background: linear-gradient(180deg, #000 0%, #111521 100%); background-attachment: fixed; color: #d0c8bf; min-height: 100vh; }
:root { --oy-sand: #D4C4A8; --oy-tan: #D4A574; --oy-radius: 4px; }
html.size-1 { --root-size: 17px; } html.size-2 { --root-size: 18px; } html.size-3 { --root-size: 20px; }
.font-size-btn { display: flex; gap: 2px; font-weight: 600; align-items: baseline; }
.font-size-btn .sz { color: rgba(232,224,214,0.68) !important; opacity: 1; transition: opacity 0.25s; line-height: 1; }
.font-size-btn .sz.active { opacity: 1; }
.font-size-btn .sz[data-size="1"] { font-size: 22px; } .font-size-btn .sz[data-size="2"] { font-size: 18px; } .font-size-btn .sz[data-size="3"] { font-size: 15px; }
.site-nav { position: sticky; top: 0; z-index: 100; background: rgba(0,0,0,0.92); -webkit-backdrop-filter: blur(12px); backdrop-filter: blur(12px); transition: background 0.3s; }
.nav-inner { max-width: 1400px; margin: 0 auto; padding: 0 40px; height: 64px; display: flex; align-items: center; }
.wordmark { font-family: 'Inter', sans-serif; font-weight: 500; font-size: 22px; color: rgba(232,224,214,0.68); letter-spacing: 0.02em; flex-shrink: 0; transition: color 0.2s; }
.wordmark:hover { color: rgba(232,224,214,0.88); }
.nav-links { display: flex; align-items: center; gap: 32px; list-style: none; padding-left: 0; margin-left: 48px; flex-shrink: 0; }
.nav-links a { font-family: 'Inter', sans-serif; font-size: 21px; font-weight: 500; letter-spacing: 0.02em; color: rgba(232,224,214,0.68); transition: color 0.2s; white-space: nowrap; }
.nav-links a:hover { color: rgba(232,224,214,0.88); }
.nav-utils { display: flex; align-items: center; gap: 12px; margin-left: auto; }
.nav-utils button, .nav-utils a { font-family: 'Inter', sans-serif; color: rgba(232,224,214,0.68); background: none; border: none; cursor: pointer; min-height: 44px; padding: 0 8px; display: flex; align-items: center; justify-content: center; transition: color 0.2s; }
.nav-utils button:hover, .nav-utils a:hover { color: rgba(232,224,214,0.88); }
.nav-utils svg { stroke: currentColor; fill: none; }
.nav-hamburger { display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 5px; min-height: 44px; padding: 0 8px; }
.nav-hamburger span { display: block; width: 22px; height: 1.5px; background: rgba(232,224,214,0.68); transition: transform 0.25s, opacity 0.2s; transform-origin: center; }
.nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.nav-accent-rule { display: block; height: 2px; border: none; background: linear-gradient(90deg, transparent 0%, rgba(122,90,74,0.35) 8%, rgba(122,90,74,0.55) 15%, rgba(122,90,74,0.28) 24%, rgba(92,58,30,0.45) 34%, rgba(92,58,30,0.65) 44%, rgba(92,58,30,0.28) 54%, rgba(122,90,74,0.50) 63%, rgba(160,128,100,0.40) 74%, rgba(160,128,100,0.28) 83%, rgba(122,90,74,0.30) 90%, transparent 100%); opacity: 0.6; }
.menu-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.45); -webkit-backdrop-filter: blur(2px); backdrop-filter: blur(2px); opacity: 0; pointer-events: none; transition: opacity 0.6s; }
.menu-overlay.open { opacity: 1; pointer-events: auto; }
.menu-strips { position: fixed; top: 0; bottom: 0; left: 0; right: 400px; z-index: 201; display: flex; flex-direction: row; overflow: hidden; opacity: 0; transition: opacity 0.5s ease 0.15s; pointer-events: none; }
.menu-strips.open { opacity: 1; pointer-events: auto; }
.strip { flex: 1; position: relative; overflow: hidden; cursor: pointer; transition: flex 1.2s cubic-bezier(0.25,0.1,0.25,1); min-width: 0; }
.strip:hover { flex: 4; }
.strip-bg { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 1.4s cubic-bezier(0.25,0.1,0.25,1); }
.strip::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 30%; z-index: 1; background: linear-gradient(to top, rgba(0,0,0,0.28) 0%, transparent 100%); pointer-events: none; }
.strip:hover .strip-bg { transform: scale(1.04); }
.strip-bottom { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.4); -webkit-backdrop-filter: blur(14px); backdrop-filter: blur(14px); padding: 40px 36px 44px; z-index: 2; opacity: 0; transition: opacity 0.8s ease 0.3s; }
.strip:hover .strip-bottom { opacity: 1; }
.strip-content { color: #fff; }
.strip-title { font-family: 'Inter', sans-serif; font-size: 34px; font-weight: 700; line-height: 1.12; margin-bottom: 8px; color: #fff; }
.strip-subtitle { font-family: 'Lora', serif; font-size: 26px; font-weight: 500; color: rgba(255,255,255,0.9); line-height: 1.25; margin-bottom: 14px; }
.strip-buttons { display: flex; gap: 12px; flex-wrap: wrap; }
.strip-btn { display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 500; color: #fff; padding: 10px 20px; border: 1px solid rgba(255,255,255,0.75); border-radius: 0; background: rgba(255,255,255,0.28); -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); letter-spacing: 0.01em; transition: all 0.3s; }
.strip-btn:hover { background: rgba(255,255,255,0.40); border-color: #fff; }
.strip-1 .strip-bg { background: linear-gradient(160deg, #c9bcac 0%, #8a7a6a 100%); }
.strip-2 .strip-bg { background: linear-gradient(160deg, #8BA89A 0%, #5a7a6a 100%); }
.strip-3 .strip-bg { background: linear-gradient(160deg, #D4A574 0%, #a07050 100%); }
.strip-4 .strip-bg { background: linear-gradient(160deg, #7a8aaa 0%, #4a5a7a 100%); }
.mobile-strips { display: none; gap: 10px; margin-bottom: 24px; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
.mobile-strips::-webkit-scrollbar { display: none; }
.mobile-strip-card { display: flex; align-items: center; gap: 12px; min-width: 200px; padding: 10px 14px; border-radius: 8px; overflow: hidden; flex-shrink: 0; position: relative; }
.mobile-strip-card .strip-bg { position: absolute; inset: 0; z-index: 0; }
.mobile-strip-card-text { position: relative; z-index: 1; }
.mobile-strip-card-title { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; color: #fff; }
.mobile-strip-card-sub { font-family: 'Lora', serif; font-size: 17px; font-weight: 500; color: rgba(255,255,255,0.8); }
.menu-panel { position: fixed; top: 0; right: -400px; bottom: 0; z-index: 202; width: 400px; background: #faf6f0; color: #2a2320; overflow-y: auto; transition: right 0.55s cubic-bezier(0.23,1,0.32,1); font-size: 17px; }
.menu-panel.open { right: 0; }
.menu-top { display: flex; justify-content: space-between; align-items: center; padding: 20px 32px 16px; }
.menu-ghost-wordmark { font-family: 'Inter', sans-serif; font-size: 22px; font-weight: 500; color: #2a2320; letter-spacing: 0.02em; opacity: 0.35; }
.menu-close { font-size: 22px; color: #2a2320 !important; background: none; border: none; cursor: pointer; min-height: 44px; min-width: 44px; display: flex; align-items: center; justify-content: center; }
.menu-content { padding: 0 32px 48px; }
.menu-nav-primary a { display: block; font-family: 'Lora', serif; font-size: 24px; font-weight: 600; color: #2a2320; padding: 10px 0; transition: opacity 0.2s; letter-spacing: -0.01em; }
.menu-nav-primary a:hover { opacity: 0.65; }
.menu-nav-label { font-size: 17px; font-weight: 500; color: #8a8078; margin-bottom: 6px; letter-spacing: 0.02em; }
.menu-nav-secondary a { display: block; font-size: 20px; font-weight: 500; color: #2a2320; padding: 8px 0; transition: opacity 0.2s; }
.menu-nav-secondary a:hover { opacity: 0.65; }
.menu-rule-tan { border: none; height: 1px; background: #D4C4A8; margin: 16px 0; opacity: 0.4; }
.menu-rule-sage { border: none; height: 1px; background: #8BA89A; margin: 16px 0; opacity: 0.3; }
.menu-nav-tertiary { display: block; margin-bottom: 12px; }
.menu-nav-tertiary a { display: block; font-size: 17px; font-weight: 450; color: #5a5048; padding: 6px 0; transition: color 0.2s; }
.menu-nav-tertiary a:hover { color: #2a2320; }
.menu-address { font-size: 17px; font-weight: 450; color: #8a8078; margin-top: 20px; letter-spacing: 0.02em; }
.menu-bottom-btns { display: flex; gap: 10px; margin-top: 20px; }
.menu-btn { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 500; padding: 10px 20px; border: 1px solid #5a5048; color: #2a2320; background: transparent; cursor: pointer; transition: border-color 0.2s, color 0.2s; }
.menu-btn:hover { border-color: #2a2320; }
.zone-hero { min-height: 80vh; display: flex; align-items: flex-end; padding: 0 60px 80px; }
.hero-inner { max-width: 640px; }
.hero-room { font-size: 1rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8078; margin-bottom: 32px; }
.hero-h1 { font-family: 'Lora', serif; font-size: clamp(1.3529rem, 2.8vw, 1.7059rem); font-weight: 600; color: #ccc5bc; line-height: 1.1; letter-spacing: -0.025em; }
.hero-sub { margin-top: 24px; font-size: 1.1rem; font-weight: 400; color: #a09888; line-height: 1.6; max-width: 480px; }
.section-nav { border-top: 1px solid #3a3430; border-bottom: 1px solid #3a3430; padding: 0 60px; display: flex; align-items: center; }
.sn-link { padding: 20px 32px; font-size: 1rem; font-weight: 500; color: #a09888; letter-spacing: 0.02em; white-space: nowrap; transition: color 0.3s; border-right: 1px solid #3a3430; }
.sn-link:last-child { border-right: none; }
.sn-link:hover { color: #d0c8bf; }
.sn-count { font-weight: 400; color: #8a8078; margin-left: 6px; font-size: 0.88rem; }
.writing-section { padding: 0 60px; }
.ws-header { padding: 64px 0 24px; border-bottom: 1px solid #2a2520; }
.ws-name { font-family: 'Lora', serif; font-size: 1.35rem; font-weight: 600; color: #d0c8bf; letter-spacing: -0.01em; }
.ws-count { font-size: 1rem; font-weight: 400; color: #8a8078; margin-left: 16px; }
.wp-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; padding: 0 0 80px; background: #2a2520; }
.wp { display: block; padding: 28px 28px 24px; background: linear-gradient(180deg, #000 0%, #111521 100%); background-attachment: fixed; cursor: pointer; transition: background 0.3s ease; }
.wp:hover { background: #141210; }
.wp-title { font-family: 'Lora', serif; font-size: 1.1rem; font-weight: 600; color: #ccc5bc; line-height: 1.3; letter-spacing: -0.01em; margin-bottom: 8px; transition: color 0.3s; }
.wp:hover .wp-title { color: #e8e0d8; }
.wp-excerpt { font-size: 0.94rem; font-weight: 400; color: #8a8078; line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.breathe { padding: 120px 60px; text-align: center; }
.breathe-text { font-family: 'Lora', serif; font-size: clamp(1.2rem, 2vw, 1.5rem); font-weight: 600; color: #a09888; line-height: 1.7; max-width: 500px; margin: 0 auto; }
.gg-intro { padding: 80px 60px 0; max-width: 700px; }
.gg-label { font-size: 1rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #8a8078; margin-bottom: 20px; }
.gg-headline { font-family: 'Lora', serif; font-size: clamp(1.3529rem, 2.8vw, 1.7059rem); font-weight: 600; color: #ccc5bc; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 16px; }
.gg-sub { font-size: 1.05rem; font-weight: 400; color: #a09888; line-height: 1.6; }
.zone-strip { border-top: 1px solid #3a3430; border-bottom: 1px solid #3a3430; padding: 0 60px; margin-top: 48px; display: flex; align-items: center; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
.zone-strip::-webkit-scrollbar { display: none; }
.ts-link { padding: 20px 28px; font-size: 1rem; font-weight: 500; color: #a09888; letter-spacing: 0.02em; white-space: nowrap; transition: color 0.3s; border-right: 1px solid #3a3430; }
.ts-link:last-child { border-right: none; }
.ts-link:hover { color: #d0c8bf; }
.ts-count { font-weight: 400; color: #8a8078; margin-left: 6px; font-size: 0.88rem; }
.territory-zone { padding: 0 60px; }
.tz-header { display: flex; justify-content: space-between; align-items: baseline; padding: 64px 0 24px; border-bottom: 1px solid #2a2520; }
.tz-name { font-family: 'Lora', serif; font-size: 1.35rem; font-weight: 600; color: #d0c8bf; letter-spacing: -0.01em; }
.tz-count { font-size: 1rem; font-weight: 400; color: #8a8078; }
.pc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 24px 0 48px; }
.pc { display: block; cursor: pointer; transition: opacity 0.4s; }
.pc:hover { opacity: 0.75; }
.pc-img { width: 100%; aspect-ratio: 4 / 5; overflow: hidden; margin-bottom: 16px; }
.pc-img svg { width: 100%; height: 100%; display: block; }
.pc-title { font-family: 'Lora', serif; font-size: 1.1rem; font-weight: 600; color: #ccc5bc; line-height: 1.3; letter-spacing: -0.01em; margin-bottom: 4px; }
.pc-artist { font-size: 1rem; font-weight: 400; color: #a09888; }
.zone-close { padding: 140px 60px; text-align: center; }
.close-num { font-family: 'Lora', serif; font-size: clamp(4rem, 8vw, 7rem); font-weight: 700; color: #a09888; letter-spacing: -0.04em; line-height: 1; }
.close-label { font-size: 1rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #8a8078; margin-top: 16px; }
.reveal { opacity: 0; transition: opacity 1.2s ease; }
.reveal-slow { opacity: 0; transition: opacity 2.4s ease; }
.reveal.visible, .reveal-slow.visible { opacity: 1; }
@media (max-width: 768px) { .reveal { transition: opacity 0.6s ease; } .reveal-slow { transition: opacity 1s ease; } }
body.light-mode { background: #faf6f0; background-attachment: scroll; color: #2a2320; }
body.light-mode .site-nav { background: rgba(250,246,240,0.92); }
body.light-mode .wordmark { color: rgba(42,35,32,0.68); }
body.light-mode .wordmark:hover { color: rgba(42,35,32,0.88); }
body.light-mode .nav-links a { color: rgba(42,35,32,0.68); }
body.light-mode .nav-links a:hover { color: rgba(42,35,32,0.88); }
body.light-mode .nav-utils button, body.light-mode .nav-utils a { color: rgba(42,35,32,0.68); }
body.light-mode .nav-utils button:hover, body.light-mode .nav-utils a:hover { color: rgba(42,35,32,0.88); }
body.light-mode .nav-hamburger span { background: rgba(42,35,32,0.68); }
body.light-mode .nav-accent-rule { opacity: 0.45; }
body.light-mode .font-size-btn .sz { color: rgba(42,35,32,0.68) !important; }
body.light-mode .hero-room { color: #5a4f47; }
body.light-mode .hero-h1 { color: #2a2320; }
body.light-mode .hero-sub { color: #5a4f47; }
body.light-mode .section-nav { border-color: #c0b8b0; }
body.light-mode .sn-link { color: #5a4f47; border-right-color: #c0b8b0; }
body.light-mode .sn-link:hover { color: #2a2320; }
body.light-mode .sn-count { color: #8a8078; }
body.light-mode .ws-header { border-bottom-color: #e0d8d0; }
body.light-mode .ws-name { color: #2a2320; }
body.light-mode .ws-count { color: #5a4f47; }
body.light-mode .wp-grid { background: #e0d8d0; }
body.light-mode .wp { background: #faf6f0; }
body.light-mode .wp:hover { background: #faf7f3; }
body.light-mode .wp-title { color: #2a2320; }
body.light-mode .wp:hover .wp-title { color: #000; }
body.light-mode .wp-excerpt { color: #5a4f47; }
body.light-mode .breathe-text { color: #5a4f47; }
body.light-mode .gg-label { color: #5a4f47; }
body.light-mode .gg-headline { color: #2a2320; }
body.light-mode .gg-sub { color: #5a4f47; }
body.light-mode .zone-strip { border-color: #c0b8b0; }
body.light-mode .ts-link { color: #5a4f47; border-right-color: #c0b8b0; }
body.light-mode .ts-link:hover { color: #2a2320; }
body.light-mode .ts-count { color: #8a8078; }
body.light-mode .tz-header { border-bottom-color: #e0d8d0; }
body.light-mode .tz-name { color: #2a2320; }
body.light-mode .tz-count { color: #5a4f47; }
body.light-mode .pc-img svg rect { fill: #e8e4de; }
body.light-mode .pc-img svg circle { fill: #e0dcd6; }
body.light-mode .pc-title { color: #2a2320; }
body.light-mode .pc-artist { color: #5a4f47; }
body.light-mode .close-num { color: #c0b8b0; }
body.light-mode .close-label { color: #8a8078; }
@media (max-width: 1100px) { .nav-links { display: none; } }
@media (max-width: 1024px) { .pc-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 768px) { .nav-inner { padding: 0 24px; } .zone-hero { padding: 0 28px 60px; min-height: 70vh; } .section-nav { padding: 0 28px; } .writing-section { padding: 0 28px; } .breathe { padding: 80px 28px; } .gg-intro { padding: 60px 28px 0; } .zone-strip { padding: 0 28px; } .territory-zone { padding: 0 28px; } .zone-close { padding: 100px 28px; } .wp-grid { grid-template-columns: 1fr; } .pc-grid { grid-template-columns: 1fr 1fr; gap: 16px; } .menu-strips { display: none !important; } .mobile-strips { display: flex; } .menu-panel { width: 100vw; right: -100vw; } .menu-panel.open { right: 0; } }
@media (max-width: 480px) { .pc-grid { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<nav class="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <a href="/" class="wordmark">oyparaploo</a>
    <ul class="nav-links">
      <li><a href="#">Writing</a></li>
      <li><a href="/portraits" class="active">Portraits</a></li>
      <li><a href="#">Our Practice</a></li>
      <li><a href="#">Dispatches</a></li>
    </ul>
    <div class="nav-utils">
      <button id="fontSizeBtn" class="font-size-btn" aria-label="Adjust font size"><span class="sz active" data-size="1">A</span><span class="sz" data-size="2">A</span><span class="sz" data-size="3">A</span></button>
      <button id="contrastBtn" aria-label="Toggle contrast" style="font-size:22px;">&#9681;</button>
      <a href="#" aria-label="Search"><svg width="22" height="22" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><circle cx="10" cy="10" r="7"/><path d="M15 15l5 5"/></svg></a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" id="navHamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="nav-accent-rule" aria-hidden="true"></div>
</nav>

<div class="menu-overlay" id="menuOverlay" aria-hidden="true"></div>

<div class="menu-strips" id="menuStrips">
  <div class="strip strip-1"><div class="strip-bg"></div><div class="strip-bottom"><div class="strip-content"><div class="strip-title">Good Grounds</div><div class="strip-subtitle">A novel in progress</div><div class="strip-buttons"><a href="#" class="strip-btn">Read &#8594;</a></div></div></div></div>
  <div class="strip strip-2"><div class="strip-bg"></div><div class="strip-bottom"><div class="strip-content"><div class="strip-title">Writing</div><div class="strip-subtitle">34 pieces, ongoing</div><div class="strip-buttons"><a href="#" class="strip-btn">Explore &#8594;</a></div></div></div></div>
  <div class="strip strip-3"><div class="strip-bg"></div><div class="strip-bottom"><div class="strip-content"><div class="strip-title">Making</div><div class="strip-subtitle">Visual &amp; object practice</div><div class="strip-buttons"><a href="#" class="strip-btn">See &#8594;</a></div></div></div></div>
  <div class="strip strip-4"><div class="strip-bg"></div><div class="strip-bottom"><div class="strip-content"><div class="strip-title">Sound</div><div class="strip-subtitle">Noir Song Frequencies</div><div class="strip-buttons"><a href="#" class="strip-btn">Listen &#8594;</a></div></div></div></div>
</div>

<div class="menu-panel" id="menuPanel" aria-hidden="true" role="dialog" aria-label="Site menu">
  <div class="menu-top"><span class="menu-ghost-wordmark" aria-hidden="true">oyparaploo</span><button class="menu-close" id="menuCloseBtn" aria-label="Close menu">&#10005;</button></div>
