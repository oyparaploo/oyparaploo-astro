---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/600.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Listening Room — Oyparaploo</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{overflow-x:hidden;font-size:var(--root-size,17px);scroll-behavior:smooth;}
html.size-1{--root-size:17px;}html.size-2{--root-size:18px;}html.size-3{--root-size:20px;}
body{font-family:'Inter',sans-serif;background:linear-gradient(to bottom,#000 0%,#040608 50%,#080c14 100%);background-attachment:fixed;color:#d0c8bf;min-height:100vh;-webkit-font-smoothing:antialiased;}
a{color:inherit;text-decoration:none;}button{font-family:inherit;border:none;background:none;cursor:pointer;}
.site-nav{position:sticky;top:0;z-index:100;background:rgba(0,0,0,0.92);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 40px;height:64px;display:flex;align-items:center;}
.wordmark{font-weight:500;font-size:22px;color:rgba(232,224,214,0.68);letter-spacing:0.02em;}
.nav-accent-rule{display:block;height:2px;border:none;background:linear-gradient(90deg,transparent 0%,rgba(122,142,160,0.35) 15%,rgba(122,142,160,0.55) 40%,rgba(122,142,160,0.28) 65%,transparent 100%);}
.page-header{max-width:800px;margin:0 auto;padding:100px 40px 48px;text-align:center;}
.page-title{font-family:'Lora',serif;font-size:clamp(1.88rem,3.5vw,2.8rem);font-weight:600;color:#d0c8bf;margin-bottom:16px;}
.page-desc{font-size:1.06rem;color:#8a8078;line-height:1.7;max-width:560px;margin:0 auto;}
.audio-section{max-width:800px;margin:0 auto;padding:0 40px 24px;}
.audio-section-title{font-family:'Lora',serif;font-size:1.18rem;font-weight:600;color:#b5ada5;padding:24px 0 16px;border-top:1px solid #3a3430;letter-spacing:0.02em;}
.audio-track{display:grid;grid-template-columns:56px 1fr 60px;gap:16px;align-items:center;padding:16px 0;border-bottom:1px solid #2a2520;transition:background 0.2s;cursor:pointer;}
.audio-track:hover{background:rgba(122,142,160,0.04);}
.track-play{width:44px;height:44px;border-radius:50%;border:1px solid #5a5048;display:flex;align-items:center;justify-content:center;transition:all 0.3s;}
.track-play:hover{border-color:#7a8ea0;background:rgba(122,142,160,0.08);}
.track-play svg{width:16px;height:16px;fill:#8a8078;margin-left:2px;transition:fill 0.2s;}
.track-play:hover svg{fill:#d0c8bf;}
.track-title{font-family:'Lora',serif;font-size:1rem;font-weight:600;color:#ccc5bc;margin-bottom:4px;}
.track-desc{font-size:0.88rem;color:#8a8078;line-height:1.5;}
.track-dur{font-size:0.82rem;color:#5a5048;text-align:right;font-variant-numeric:tabular-nums;}
.waveform{max-width:800px;margin:0 auto;padding:48px 40px;text-align:center;}
.waveform svg{width:100%;max-width:600px;height:60px;opacity:0.3;}
@media(max-width:768px){.page-header{padding:60px 24px 32px;}.audio-section{padding:0 24px 16px;}.waveform{padding:32px 24px;}.audio-track{grid-template-columns:44px 1fr 48px;gap:12px;}}
</style>
</head>
<body>

<nav class="site-nav">
  <div class="nav-inner"><a href="/" class="wordmark">oyparaploo</a></div>
  <div class="nav-accent-rule"></div>
</nav>

<div class="page-header">
  <h1 class="page-title">The Listening Room</h1>
  <p class="page-desc">Audio guides to the practice. Close your eyes. The space between the note and the silence holds the entire work.</p>
</div>

