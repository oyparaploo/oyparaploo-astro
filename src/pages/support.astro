---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/500.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Support — Oyparaploo</title>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
p,h1,h2,h3,h4,li,blockquote{text-wrap:pretty;}
em,i,cite,address,dfn,var{font-style:normal;}
*{font-style:normal;}
html{overflow-x:hidden;scroll-behavior:smooth;font-size:var(--root-size,17px);-webkit-text-size-adjust:100%;text-size-adjust:100%;}
body{font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden;overflow-wrap:break-word;word-break:break-word;transition:background 0.4s ease,color 0.3s ease;background:linear-gradient(to bottom,#000000 0%,#000000 5%,#020203 12%,#040507 20%,#060810 30%,#080a13 40%,#0a0d16 50%,#0b0f18 60%,#0d111b 70%,#0e121d 80%,#10141f 90%,#111521 100%);background-attachment:fixed;min-height:100vh;}
a{color:inherit;text-decoration:none;}
a,button,[role="button"],select{touch-action:manipulation;-webkit-tap-highlight-color:transparent;}
button{font-family:inherit;border:none;background:none;cursor:pointer;}
ul,ol{list-style:none;}
img{max-width:100%;height:auto;display:block;}
:root{--oy-sand:#D4C4A8;--oy-tan:#D4A574;--oy-radius:4px;}
html.size-1{--root-size:17px;}html.size-2{--root-size:18px;}html.size-3{--root-size:20px;}
.font-size-btn{display:flex;gap:2px;font-weight:600;align-items:baseline;}
.font-size-btn .sz{color:rgba(232,224,214,0.68) !important;opacity:1;transition:opacity 0.25s;line-height:1;}
.font-size-btn .sz.active{opacity:1;}
.font-size-btn .sz[data-size="1"]{font-size:22px;}.font-size-btn .sz[data-size="2"]{font-size:18px;}.font-size-btn .sz[data-size="3"]{font-size:15px;}
.site-nav{position:sticky;top:0;z-index:100;background:rgba(0,0,0,0.92);-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);transition:background 0.3s;}
.nav-inner{max-width:1400px;margin:0 auto;padding:0 40px;height:64px;display:flex;align-items:center;}
.wordmark{font-family:'Inter',sans-serif;font-weight:500;font-size:22px;color:rgba(232,224,214,0.68);letter-spacing:0.02em;flex-shrink:0;transition:color 0.2s;}
.wordmark:hover{color:rgba(232,224,214,0.88);}
.nav-links{display:flex;align-items:center;gap:32px;list-style:none;padding-left:0;margin-left:48px;flex-shrink:0;}
.nav-links a{font-family:'Inter',sans-serif;font-size:21px;font-weight:500;letter-spacing:0.02em;color:rgba(232,224,214,0.68);transition:color 0.2s;white-space:nowrap;}
.nav-links a:hover{color:rgba(232,224,214,0.88);}
.nav-utils{display:flex;align-items:center;gap:12px;margin-left:auto;}
.nav-utils button,.nav-utils a{font-family:'Inter',sans-serif;color:rgba(232,224,214,0.68);background:none;border:none;cursor:pointer;min-height:44px;padding:0 8px;display:flex;align-items:center;justify-content:center;transition:color 0.2s;}
.nav-utils button:hover,.nav-utils a:hover{color:rgba(232,224,214,0.88);}
.nav-utils svg{stroke:currentColor;fill:none;}
.nav-hamburger{display:flex;flex-direction:column;justify-content:center;align-items:center;gap:5px;min-height:44px;padding:0 8px;}
.nav-hamburger span{display:block;width:22px;height:1.5px;background:rgba(232,224,214,0.68);transition:transform 0.25s,opacity 0.2s;transform-origin:center;}
.nav-hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);}
.nav-hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.nav-hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);}
.nav-accent-rule{display:block;height:2px;border:none;background:linear-gradient(90deg,transparent 0%,rgba(122,90,74,0.35) 8%,rgba(122,90,74,0.55) 15%,rgba(122,90,74,0.28) 24%,rgba(92,58,30,0.45) 34%,rgba(92,58,30,0.65) 44%,rgba(92,58,30,0.28) 54%,rgba(122,90,74,0.50) 63%,rgba(160,128,100,0.40) 74%,rgba(160,128,100,0.28) 83%,rgba(122,90,74,0.30) 90%,transparent 100%);opacity:0.6;}
.menu-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.45);opacity:0;pointer-events:none;transition:opacity 0.6s;}
.menu-overlay.open{opacity:1;pointer-events:auto;}
.menu-strips{position:fixed;top:0;bottom:0;left:0;right:400px;z-index:201;display:flex;flex-direction:row;overflow:hidden;opacity:0;transition:opacity 0.5s ease 0.15s;pointer-events:none;}
.menu-strips.open{opacity:1;pointer-events:auto;}
.strip{flex:1;position:relative;overflow:hidden;cursor:pointer;transition:flex 1.2s cubic-bezier(0.25,0.1,0.25,1);min-width:0;}
.strip:hover{flex:4;}
.strip-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform 1.4s cubic-bezier(0.25,0.1,0.25,1);}
.strip::after{content:'';position:absolute;bottom:0;left:0;right:0;height:30%;z-index:1;background:linear-gradient(to top,rgba(0,0,0,0.28) 0%,transparent 100%);pointer-events:none;}
.strip:hover .strip-bg{transform:scale(1.04);}
.strip-bottom{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.4);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);padding:40px 36px 44px;z-index:2;opacity:0;transition:opacity 0.8s ease 0.3s;}
.strip:hover .strip-bottom{opacity:1;}
.strip-content{color:#fff;}
.strip-title{font-family:'Inter',sans-serif;font-size:34px;font-weight:700;line-height:1.12;margin-bottom:8px;color:#fff;}
.strip-subtitle{font-family:'Lora',serif;font-size:26px;font-weight:500;color:rgba(255,255,255,0.9);line-height:1.25;margin-bottom:14px;}
.strip-buttons{display:flex;gap:12px;flex-wrap:wrap;}
.strip-btn{display:inline-flex;align-items:center;gap:8px;font-family:'Inter',sans-serif;font-size:17px;font-weight:500;color:#fff;padding:10px 20px;border:1px solid rgba(255,255,255,0.75);border-radius:0;background:rgba(255,255,255,0.28);-webkit-backdrop-filter:blur(4px);backdrop-filter:blur(4px);letter-spacing:0.01em;transition:all 0.3s;}
.strip-btn:hover{background:rgba(255,255,255,0.40);border-color:#fff;}
.strip-1 .strip-bg{background:linear-gradient(160deg,#c9bcac 0%,#8a7a6a 100%);}
.strip-2 .strip-bg{background:linear-gradient(160deg,#8BA89A 0%,#5a7a6a 100%);}
.strip-3 .strip-bg{background:linear-gradient(160deg,#D4A574 0%,#a07050 100%);}
.strip-4 .strip-bg{background:linear-gradient(160deg,#7a8aaa 0%,#4a5a7a 100%);}
.mobile-strips{display:none;gap:10px;margin-bottom:24px;overflow-x:auto;scrollbar-width:none;}
.mobile-strips::-webkit-scrollbar{display:none;}
.mobile-strip-card{flex:0 0 140px;height:100px;border-radius:var(--oy-radius);position:relative;overflow:hidden;cursor:pointer;border:1px solid rgba(0,0,0,0.28);}
.mobile-strip-card .strip-bg{position:absolute;inset:0;border-radius:var(--oy-radius);}
.mobile-strip-card::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.5) 0%,transparent 60%);border-radius:var(--oy-radius);}
.mobile-strip-card-text{position:absolute;bottom:10px;left:12px;right:8px;z-index:2;color:#fff;}
.mobile-strip-card-title{font-family:'Inter',sans-serif;font-size:17px;font-weight:600;line-height:1.2;margin-bottom:2px;}
.mobile-strip-card-sub{font-family:'Lora',serif;font-size:17px;font-weight:500;color:rgba(255,255,255,0.75);line-height:1.2;}
.menu-panel{position:fixed;top:0;right:0;bottom:0;z-index:201;width:400px;max-width:90vw;background:#faf6f0;color:#2a2320;font-size:17px;clip-path:inset(16px 20px calc(100% - 68px) calc(100% - 200px) round var(--oy-radius));transition:clip-path 0.6s cubic-bezier(0.4,0,0.1,1),opacity 0.2s ease;overflow-y:auto;padding:24px 32px 40px;pointer-events:none;opacity:0;}
.menu-panel.open{clip-path:inset(0 0 0 0 round 0);pointer-events:auto;opacity:1;}
.menu-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;}
.menu-ghost-wordmark{font-family:'Inter',sans-serif;font-size:22px;font-weight:500;color:#2a2320;opacity:0.38;letter-spacing:0.02em;user-select:none;pointer-events:none;}
.menu-close{width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:22px;color:#2a2320 !important;cursor:pointer;}
.menu-nav-primary a{font-family:'Lora',serif;font-size:24px;font-weight:600;color:#2a2320;display:block;padding:10px 0;line-height:1.2;transition:opacity 0.2s;}
.menu-nav-primary a:hover{opacity:0.55;}
.menu-rule-tan{height:2px;border:none;background:var(--oy-tan);margin:20px 0;}
.menu-rule-sage{height:2px;border:none;background:#8BA89A;margin:20px 0;}
.menu-nav-secondary a,.menu-nav-tertiary a{font-family:'Inter',sans-serif;font-size:18px;font-weight:600;color:#2a2320;display:block;padding:4px 0;transition:opacity 0.2s;}
.menu-nav-secondary a:hover,.menu-nav-tertiary a:hover{opacity:0.55;}
.menu-address{font-family:'Inter',sans-serif;font-size:19px;font-weight:500;color:#5a4f47;margin-top:20px;line-height:1.6;}
.menu-bottom-btns{display:flex;gap:8px;margin-top:20px;}
.menu-bottom-btns .menu-btn{font-family:'Inter',sans-serif;font-size:16px;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;color:#2a2320;border:1px solid rgba(42,35,32,0.40);padding:8px 16px;border-radius:var(--oy-radius);background:transparent;cursor:pointer;transition:background 0.2s,color 0.2s,border-color 0.2s;min-height:44px;}
.menu-bottom-btns .menu-btn:hover{background:#2a2320;color:#faf8f5;border-color:#2a2320;}
.reveal{opacity:0;transition:opacity 1s ease;}
.reveal.visible{opacity:1;}
.bottom-safe{padding-bottom:env(safe-area-inset-bottom,0px);}
.support-container{max-width:1000px;margin:0 auto;padding:0 40px;}
.support-wide{max-width:1200px;margin:0 auto;padding:0 40px;}
.support-hero{padding:96px 0 48px;border-bottom:1px solid #3a3430;}
.support-eyebrow{font-size:1rem;font-weight:600;color:#a09888;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:20px;}
.support-title{font-family:'Lora',serif;font-size:clamp(23px,2.8vw,29px);font-weight:600;color:#d0c8bf;letter-spacing:-0.01em;line-height:1.2;max-width:600px;margin-bottom:20px;}
.support-description{font-size:1.0588rem;font-weight:400;color:#b5ada5;line-height:1.75;max-width:580px;margin-bottom:32px;}
.quick-actions{display:flex;flex-wrap:wrap;gap:10px;}
.quick-link{font-size:1rem;font-weight:500;color:#d0c8bf;background:transparent;border:1px solid #5a5048;padding:10px 22px;border-radius:var(--oy-radius);transition:border-color 0.2s,color 0.2s;min-height:44px;display:inline-flex;align-items:center;}
.quick-link:hover{border-color:#d0c8bf;color:#e8e0d8;}
.tiers-section{padding:56px 0;border-bottom:1px solid #3a3430;}
.section-label{font-size:1rem;font-weight:600;color:#a09888;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px;}
.section-title{font-family:'Lora',serif;font-size:clamp(23px,2.8vw,29px);font-weight:600;color:#d0c8bf;margin-bottom:8px;}
.section-desc{font-size:1rem;font-weight:400;color:#8a8078;line-height:1.65;max-width:520px;margin-bottom:36px;}
.tier-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.tier-card{border:1px solid #3a3430;border-radius:var(--oy-radius);padding:32px 28px;display:flex;flex-direction:column;transition:border-color 0.2s,background 0.2s;}
.tier-card:hover{border-color:#5a5048;background:#141210;}
.tier-featured{border-color:#8a6e50;}
.tier-featured:hover{border-color:#c4956a;}
.tier-name{font-family:'Lora',serif;font-size:1.2353rem;font-weight:600;color:#ccc5bc;margin-bottom:8px;}
.tier-price{font-size:1.0588rem;font-weight:600;color:#d0c8bf;margin-bottom:4px;}
.tier-desc{font-size:1rem;font-weight:400;color:#b5ada5;line-height:1.65;margin-top:20px;padding-top:20px;border-top:1px solid #2a2520;flex:1;}
.tier-benefits{margin-top:20px;padding-top:16px;border-top:1px solid #2a2520;}
.tier-benefit{font-size:1rem;font-weight:400;color:#8a8078;line-height:1.65;padding:6px 0;}
.tier-cta{display:block;text-align:center;font-size:1rem;font-weight:500;color:#d0c8bf;background:transparent;border:1px solid #5a5048;padding:12px 20px;border-radius:var(--oy-radius);margin-top:24px;transition:border-color 0.2s,color 0.2s;min-height:44px;}
.tier-cta:hover{border-color:#d0c8bf;color:#e8e0d8;}
.tier-featured .tier-cta{border-color:#8a6e50;}
.tier-featured .tier-cta:hover{border-color:#c4956a;color:#e8e0d8;}
.circle-section{background:linear-gradient(to bottom,#2a2320,#3a3028);padding:64px 0;margin:0 -9999px;padding-left:9999px;padding-right:9999px;}
.circle-inner{max-width:1000px;margin:0 auto;}
.circle-title{font-family:'Lora',serif;font-size:clamp(23px,2.8vw,29px);font-weight:600;color:#ffffff;margin-bottom:12px;}
.circle-intro{font-size:1.0588rem;font-weight:400;color:#ccc5bc;line-height:1.75;max-width:580px;margin-bottom:40px;}
.circle-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;}
.circle-card{border:1px solid #5a5048;border-radius:var(--oy-radius);padding:28px 24px;transition:border-color 0.2s,background 0.2s;}
.circle-card:hover{border-color:#8a8078;background:rgba(255,255,255,0.03);}
.circle-card-name{font-family:'Lora',serif;font-size:1.2353rem;font-weight:600;color:#e8e0d8;margin-bottom:8px;}
.circle-card-desc{font-size:1rem;font-weight:400;color:#b5ada5;line-height:1.65;}
.contribute-section{padding:56px 0;border-bottom:1px solid #3a3430;}
.contribute-card{max-width:620px;margin:0 auto;border:1px solid #3a3430;border-radius:var(--oy-radius);padding:40px 36px;text-align:center;}
.contribute-title{font-family:'Lora',serif;font-size:clamp(23px,2.8vw,29px);font-weight:600;color:#d0c8bf;margin-bottom:12px;}
.contribute-desc{font-size:1rem;font-weight:400;color:#b5ada5;line-height:1.65;max-width:480px;margin:0 auto 28px;}
.amount-row{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:28px;}
.amount-pill{font-size:1rem;font-weight:500;color:#b5ada5;background:transparent;border:1px solid #3a3430;padding:10px 22px;border-radius:var(--oy-radius);cursor:pointer;transition:border-color 0.2s,color 0.2s;min-height:44px;}
.amount-pill:hover{border-color:#5a5048;color:#d0c8bf;}
.amount-pill.active{border-color:#8a6e50;color:#d8d0c8;}
.contribute-cta{display:inline-block;font-size:1rem;font-weight:500;color:#d0c8bf;background:transparent;border:1px solid #5a5048;padding:12px 32px;border-radius:var(--oy-radius);transition:border-color 0.2s,color 0.2s;min-height:44px;}
.contribute-cta:hover{border-color:#d0c8bf;color:#e8e0d8;}
.contribute-note{font-size:1rem;font-weight:400;color:#8a8078;margin-top:20px;}
.ways-section{padding:56px 0 96px;}
.ways-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:36px;}
.way-card{border:1px solid #3a3430;border-radius:var(--oy-radius);padding:28px 24px;display:block;transition:border-color 0.2s,background 0.2s;}
.way-card:hover{border-color:#5a5048;background:#141210;}
.way-title{font-family:'Lora',serif;font-size:1.2353rem;font-weight:600;color:#ccc5bc;margin-bottom:10px;transition:color 0.2s;}
.way-card:hover .way-title{color:#e8e0d8;}
.way-desc{font-size:1rem;font-weight:400;color:#8a8078;line-height:1.65;}
.way-arrow{font-size:1rem;font-weight:500;color:#a09888;margin-top:16px;display:block;}
body.light-mode{background:#ffffff;background-image:linear-gradient(to bottom,#ffffff 0px,#ffffff 300px,#fdfcfb 700px,#f9f7f4 100%);background-attachment:scroll;}
body.light-mode .site-nav{background:rgba(255,255,255,0.97);}
body.light-mode .wordmark{color:#333;}body.light-mode .wordmark:hover{color:#5c3a1e;}
body.light-mode .nav-links a{color:#333;}body.light-mode .nav-links a:hover{color:#5c3a1e;}
body.light-mode .nav-utils button,body.light-mode .nav-utils a{color:#000;}
body.light-mode .nav-hamburger span{background:#333;}
body.light-mode .font-size-btn .sz{color:#000 !important;}
body.light-mode .nav-accent-rule{opacity:1;}
body.light-mode .support-hero{border-bottom-color:#d0c9c4;}
body.light-mode .support-eyebrow{color:#5a4f47;}
body.light-mode .support-title{color:#2a2320;}
body.light-mode .support-description{color:#4a4038;}
body.light-mode .quick-link{color:#2a2320;border-color:#c4bdb8;}
body.light-mode .quick-link:hover{border-color:#2a2320;}
body.light-mode .tiers-section{border-bottom-color:#d0c9c4;}
body.light-mode .section-label{color:#5a4f47;}
body.light-mode .section-title{color:#2a2320;}
body.light-mode .section-desc{color:#5a4f47;}
body.light-mode .tier-card{border-color:#c4bdb8;}
body.light-mode .tier-card:hover{border-color:#959088;background:#f7f4f2;}
body.light-mode .tier-featured{border-color:#7a5e42;}
body.light-mode .tier-name{color:#2a2320;}
body.light-mode .tier-price{color:#2a2320;}
body.light-mode .tier-desc{color:#4a4038;border-top-color:#e0d9d4;}
body.light-mode .tier-benefits{border-top-color:#e0d9d4;}
body.light-mode .tier-benefit{color:#5a4f47;}
body.light-mode .tier-cta{color:#2a2320;border-color:#c4bdb8;}
body.light-mode .circle-section{background:linear-gradient(to bottom,#f0ebe5,#e8e2dc);}
body.light-mode .circle-title{color:#2a2320;}
body.light-mode .circle-intro{color:#4a4038;}
body.light-mode .circle-card{border-color:#c4bdb8;}
body.light-mode .circle-card-name{color:#2a2320;}
body.light-mode .circle-card-desc{color:#4a4038;}
body.light-mode .contribute-section{border-bottom-color:#d0c9c4;}
body.light-mode .contribute-card{border-color:#c4bdb8;}
body.light-mode .contribute-title{color:#2a2320;}
body.light-mode .contribute-desc{color:#4a4038;}
body.light-mode .amount-pill{color:#4a4038;border-color:#c4bdb8;}
body.light-mode .amount-pill.active{border-color:#7a5e42;color:#2a2320;}
body.light-mode .contribute-cta{color:#2a2320;border-color:#c4bdb8;}
body.light-mode .contribute-note{color:#5a4f47;}
body.light-mode .way-card{border-color:#c4bdb8;}
body.light-mode .way-card:hover{border-color:#959088;background:#f7f4f2;}
body.light-mode .way-title{color:#2a2320;}
body.light-mode .way-desc{color:#5a4f47;}
body.light-mode .way-arrow{color:#5a4f47;}
@media(max-width:1100px){.nav-links{display:none;}}
@media(max-width:1024px){.tier-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){.nav-inner{padding:0 24px;}.menu-strips{display:none;}.mobile-strips{display:flex;}.menu-panel{width:100%;max-width:100%;}.reveal{transition:opacity 0.6s ease;}.support-container,.support-wide{padding:0 24px;}.support-hero{padding:56px 0 36px;}.tier-grid{grid-template-columns:1fr;}.circle-grid{grid-template-columns:1fr;}.ways-grid{grid-template-columns:1fr;}.contribute-card{padding:32px 24px;}}
@media(max-width:480px){.support-container,.support-wide{padding:0 24px;}.quick-actions{gap:8px;}}
</style>
</head>
<body>

<nav class="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <a href="/" class="wordmark">oyparaploo</a>
    <ul class="nav-links">
      <li><a href="#">Writing</a></li>
      <li><a href="/portraits">Portraits</a></li>
      <li><a href="/our-practice">Practice</a></li>
      <li><a href="#">Dispatches</a></li>
    </ul>
    <div class="nav-utils">
      <button id="fontSizeBtn" class="font-size-btn" aria-label="Adjust font size"><span class="sz active" data-size="1">A</span><span class="sz" data-size="2">A</span><span class="sz" data-size="3">A</span></button>
      <button id="contrastBtn" aria-label="Toggle contrast" style="font-size:22px;">◑</button>
      <a href="#" aria-label="Search"><svg width="22" height="22" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><circle cx="10" cy="10" r="7"/><path d="M15 15l5 5"/></svg></a>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" id="navHamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="nav-accent-rule" aria-hidden="true"></div>
</nav>

