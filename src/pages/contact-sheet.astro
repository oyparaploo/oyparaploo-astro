---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/600.css';
import '@fontsource/lora/700.css';
---

<!DOCTYPE html>
<html lang="en" class="size-1">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Sheet — Oyparaploo</title>
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
* { font-style: normal; }
html { font-size: var(--root-size, 17px); }
body { font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; background: #fff; color: #1a1a1a; overflow-x: hidden; }
a { color: inherit; text-decoration: none; }
button { font-family: inherit; border: none; background: none; cursor: pointer; }
:root { --oy-radius: 0; }
html.size-1 { --root-size: 17px; } html.size-2 { --root-size: 18px; } html.size-3 { --root-size: 20px; }
.top-bar { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; mix-blend-mode: difference; pointer-events: none; }
.top-bar > * { pointer-events: auto; }
.tb-brand { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 600; color: #fff; letter-spacing: 0.06em; text-transform: uppercase; }
.tb-right { display: flex; gap: 16px; align-items: center; }
.tb-count { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 500; color: rgba(255,255,255,0.5); }
.nav-hamburger { display: flex; flex-direction: column; gap: 5px; min-height: 44px; padding: 0 8px; align-items: center; justify-content: center; }
.nav-hamburger span { display: block; width: 22px; height: 1.5px; background: #fff; transition: transform 0.25s, opacity 0.2s; transform-origin: center; }
.nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
.nav-hamburger.open span:nth-child(2) { opacity: 0; }
.nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
.contact-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 2px; }
.cg-item { position: relative; overflow: hidden; cursor: pointer; aspect-ratio: 1; }
.cg-item-fill { position: absolute; inset: 0; transition: transform 0.6s; }
.cg-item:hover .cg-item-fill { transform: scale(1.08); }
.cg-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.7); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 16px; opacity: 0; transition: opacity 0.4s; z-index: 2; }
.cg-item:hover .cg-overlay { opacity: 1; }
.cg-overlay-register { font-family: 'Inter', sans-serif; font-size: 17px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px; }
.cg-overlay-title { font-family: 'Lora', serif; font-size: 17px; font-weight: 600; color: #fff; line-height: 1.3; }
.reg-origin { color: #D4A574; }
.reg-witness { color: #c87a82; }
.reg-declaration { color: #6aaccc; }
.reg-conversation { color: #6ab87a; }
.reg-unfolding { color: #c4aad4; }
.reg-making { color: #8a6a9a; }
.f1 { background: linear-gradient(135deg, #6a4a7a 0%, #3a2a4a 100%); }
.f2 { background: linear-gradient(135deg, #c4956a 0%, #8a6040 100%); }
.f3 { background: linear-gradient(135deg, #7a8aaa 0%, #4a5a7a 100%); }
.f4 { background: linear-gradient(135deg, #5a7a5a 0%, #3a5a3a 100%); }
.f5 { background: linear-gradient(135deg, #9e3a2a 0%, #6a2a1e 100%); }
.f6 { background: linear-gradient(135deg, #8a7a6a 0%, #5a4a3a 100%); }
.f7 { background: linear-gradient(135deg, #c4bac4 0%, #8a7a8a 100%); }
.f8 { background: linear-gradient(135deg, #a8c8e0 0%, #6a8aaa 100%); }
.f9 { background: linear-gradient(135deg, #B2916C 0%, #8a6a4a 100%); }
.f10 { background: linear-gradient(135deg, #662a1e 0%, #3a1a10 100%); }
.f11 { background: linear-gradient(135deg, #a8d4b0 0%, #6a9a7a 100%); }
.f12 { background: linear-gradient(135deg, #D4A574 0%, #a07050 100%); }
.span-2c { grid-column: span 2; }
.span-2r { grid-row: span 2; }
.span-2c.span-2r { aspect-ratio: auto; }
.menu-overlay { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.6); opacity: 0; pointer-events: none; transition: opacity 0.6s; }
.menu-overlay.open { opacity: 1; pointer-events: auto; }
.menu-panel { position: fixed; top: 0; right: 0; bottom: 0; z-index: 201; width: 400px; max-width: 90vw; background: #faf6f0; color: #2a2320; font-size: 17px; clip-path: inset(16px 20px calc(100% - 68px) calc(100% - 200px) round 4px); transition: clip-path 0.6s cubic-bezier(0.4,0,0.1,1), opacity 0.2s ease; overflow-y: auto; padding: 24px 32px 40px; pointer-events: none; opacity: 0; }
.menu-panel.open { clip-path: inset(0 0 0 0 round 0); pointer-events: auto; opacity: 1; }
.menu-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; }
.menu-ghost-wordmark { font-family: 'Inter', sans-serif; font-size: 22px; font-weight: 500; color: #2a2320; opacity: 0.38; }
.menu-close { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: #2a2320 !important; cursor: pointer; }
.menu-nav-primary a { font-family: 'Lora', serif; font-size: 24px; font-weight: 600; color: #2a2320; display: block; padding: 10px 0; transition: opacity 0.2s; }
.menu-nav-primary a:hover { opacity: 0.55; }
.menu-rule-tan { height: 2px; border: none; background: #D4A574; margin: 20px 0; }
.menu-rule-sage { height: 2px; border: none; background: #8BA89A; margin: 20px 0; }
.menu-nav-secondary a, .menu-nav-tertiary a { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 600; color: #2a2320; display: block; padding: 4px 0; }
.menu-address { font-family: 'Inter', sans-serif; font-size: 19px; font-weight: 500; color: #5a4f47; margin-top: 20px; }
.menu-bottom-btns { display: flex; gap: 8px; margin-top: 20px; }
.menu-bottom-btns .menu-btn { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: #2a2320; border: 1px solid rgba(42,35,32,0.40); padding: 8px 16px; border-radius: 4px; background: transparent; cursor: pointer; min-height: 44px; }
@media (max-width: 900px) { .contact-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 600px) { .contact-grid { grid-template-columns: repeat(3, 1fr); } .span-2c { grid-column: span 1; } .span-2r { grid-row: span 1; } .menu-panel { width: 100%; max-width: 100%; } }
</style>
</head>
<body>

<div class="top-bar">
  <a href="/" class="tb-brand">Oyparaploo</a>
  <div class="tb-right"><span class="tb-count">67 works</span><button class="nav-hamburger" id="navHamburger"><span></span><span></span><span></span></button></div>
</div>

<div class="contact-grid">
<a class="cg-item" href="#"><div class="cg-item-fill f1"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">A Word Is A Room</div></div></a>
<a class="cg-item span-2c" href="#"><div class="cg-item-fill f2"></div><div class="cg-overlay"><div class="cg-overlay-register reg-witness">Witness</div><div class="cg-overlay-title">Hand Me the Matches</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f3"></div><div class="cg-overlay"><div class="cg-overlay-register reg-declaration">Declaration</div><div class="cg-overlay-title">Big Time Art</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f4"></div><div class="cg-overlay"><div class="cg-overlay-register reg-conversation">Conversation</div><div class="cg-overlay-title">Blue Ball Mess And Mix</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f5"></div><div class="cg-overlay"><div class="cg-overlay-register reg-witness">Witness</div><div class="cg-overlay-title">Broken Caucasian Ruler</div></div></a>
<a class="cg-item span-2r" href="#"><div class="cg-item-fill f6"></div><div class="cg-overlay"><div class="cg-overlay-register reg-unfolding">Unfolding</div><div class="cg-overlay-title">Tier Heart Wetness</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f7"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">Compost Aroma Almost Poem</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f8"></div><div class="cg-overlay"><div class="cg-overlay-register reg-conversation">Conversation</div><div class="cg-overlay-title">Early Morning with a Baobab Tree</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f9"></div><div class="cg-overlay"><div class="cg-overlay-register reg-declaration">Declaration</div><div class="cg-overlay-title">Border Wall Size Mirror</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f10"></div><div class="cg-overlay"><div class="cg-overlay-register reg-witness">Witness</div><div class="cg-overlay-title">Bowed Cello Playing Sound</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f11"></div><div class="cg-overlay"><div class="cg-overlay-register reg-unfolding">Unfolding</div><div class="cg-overlay-title">Fluid Mosaic</div></div></a>
<a class="cg-item span-2c" href="#"><div class="cg-item-fill f12"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">Noir Song</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f3"></div><div class="cg-overlay"><div class="cg-overlay-register reg-declaration">Declaration</div><div class="cg-overlay-title">Palimpsest</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f1"></div><div class="cg-overlay"><div class="cg-overlay-register reg-making">Making</div><div class="cg-overlay-title">Plantless Garden</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f5"></div><div class="cg-overlay"><div class="cg-overlay-register reg-witness">Witness</div><div class="cg-overlay-title">Red Tongues First</div></div></a>
<a class="cg-item span-2r" href="#"><div class="cg-item-fill f8"></div><div class="cg-overlay"><div class="cg-overlay-register reg-conversation">Conversation</div><div class="cg-overlay-title">Careful Children</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f9"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">Voices</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f4"></div><div class="cg-overlay"><div class="cg-overlay-register reg-conversation">Conversation</div><div class="cg-overlay-title">What Went Wrong?</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f7"></div><div class="cg-overlay"><div class="cg-overlay-register reg-unfolding">Unfolding</div><div class="cg-overlay-title">Sturdy Pockets</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f2"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">The Breath</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f10"></div><div class="cg-overlay"><div class="cg-overlay-register reg-declaration">Declaration</div><div class="cg-overlay-title">The River</div></div></a>
<a class="cg-item span-2c" href="#"><div class="cg-item-fill f6"></div><div class="cg-overlay"><div class="cg-overlay-register reg-witness">Witness</div><div class="cg-overlay-title">Brown Paint</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f11"></div><div class="cg-overlay"><div class="cg-overlay-register reg-making">Making</div><div class="cg-overlay-title">Flying Concrete Square Room</div></div></a>
<a class="cg-item" href="#"><div class="cg-item-fill f12"></div><div class="cg-overlay"><div class="cg-overlay-register reg-origin">Origin</div><div class="cg-overlay-title">Thirty Years</div></div></a>
</div>

<div class="menu-overlay" id="menuOverlay"></div>
<div class="menu-panel" id="menuPanel" role="dialog"><div class="menu-top"><span class="menu-ghost-wordmark">oyparaploo</span><button class="menu-close" id="menuCloseBtn">&#10005;</button></div><div class="menu-content"><nav class="menu-nav-primary"><a href="#">Writing</a><a href="#">Making</a><a href="#">Good Grounds</a></nav><hr class="menu-rule-tan"><nav class="menu-nav-secondary"><a href="#">Our Practice</a><a href="#">Music Artists</a><a href="#">Collaborators</a><a href="#">Methodology</a></nav><hr class="menu-rule-sage"><nav class="menu-nav-tertiary"><a href="#">Support</a><a href="#">Archive</a><a href="#">Calendar</a><a href="#">Contact</a></nav><div class="menu-address">Minneapolis ~ Saint Paul</div><div class="menu-bottom-btns"><button class="menu-btn">Subscribe</button></div></div></div>

<script>
var navH=document.getElementById('navHamburger'),menuC=document.getElementById('menuCloseBtn'),menuO=document.getElementById('menuOverlay'),menuP=document.getElementById('menuPanel');
navH.addEventListener('click',function(){menuO.classList.add('open');menuP.classList.add('open');navH.classList.add('open')});
menuC.addEventListener('click',function(){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')});
menuO.addEventListener('click',function(){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')});
document.addEventListener('keydown',function(e){if(e.key==='Escape'){menuO.classList.remove('open');menuP.classList.remove('open');navH.classList.remove('open')}});
</script>
</body>
</html>